---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CategoryPills from '../../components/CategoryPills.astro';
import AppCard from '../../components/AppCard.astro';
import { getAppsByCategory } from '../../lib/apps';

const { cat } = Astro.params;

const validCategories = ['games', 'apps', 'tools', 'social'];

if (!cat || !validCategories.includes(cat)) {
  return Astro.redirect('/');
}

const categoryName = cat.charAt(0).toUpperCase() + cat.slice(1);
const filteredApps = await getAppsByCategory(cat);
---

<BaseLayout title={`${categoryName} - Rrmod`} description={`Download the latest ${categoryName.toLowerCase()} mod APK for Android.`}>
  <div class="mx-auto max-w-[1200px] px-6 py-10 md:px-8">

    <!-- Page Title -->
    <h1 class="display-font mb-6 inline-block rotate-[-1deg] border-[3px] border-[#101010] bg-[#ffee32] px-5 py-3 text-2xl uppercase text-[#101010] shadow-[6px_6px_0_#101010] md:text-3xl">{categoryName}</h1>

    <!-- Category Pills -->
    <div class="mb-6">
      <CategoryPills activeCategory={cat} />
    </div>

    <!-- App Grid -->
    {filteredApps.length > 0 ? (
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4 md:gap-6">
        {filteredApps.map((app) => (
          <AppCard app={app} />
        ))}
      </div>
    ) : (
      <div class="py-20 text-center">
        <p class="brutal-card inline-block px-6 py-4 text-sm font-black text-[#101010]">No apps found in this category.</p>
      </div>
    )}

  </div>
</BaseLayout>
