---
import BaseLayout from "../layouts/BaseLayout.astro";
import AppCard from "../components/AppCard.astro";
import SearchBar from "../components/SearchBar.astro";
import CategoryPills from "../components/CategoryPills.astro";
import { getAllApps } from "../lib/apps";

const allApps = await getAllApps();
const gameApps = allApps.filter((app) => app.category === "games");
const nonGameApps = allApps.filter((app) => app.category !== "games");
---

<BaseLayout
    title="Rrmod - Download Mod APK Games & Apps"
    description="Download trusted Android mod games & applications. The latest and most updated mod APK collection."
>
    <!-- ============================================ -->
    <!-- 1. HERO SECTION                              -->
    <!-- ============================================ -->
    <section
        class="relative isolate overflow-hidden border-b-[4px] border-[#101010] bg-[#ffee32] pb-8 pt-20 md:pb-16 md:pt-28"
    >
        <div class="absolute inset-0 opacity-25" aria-hidden="true" style="background-image: radial-gradient(#101010 1.5px, transparent 1.5px); background-size: 18px 18px;"></div>
        <div class="absolute -right-10 top-20 h-28 w-72 rotate-6 border-[4px] border-[#101010] bg-[#ff4fd8] shadow-[8px_8px_0_#101010]" aria-hidden="true"></div>
        <div class="absolute -left-12 bottom-10 h-24 w-64 -rotate-6 border-[4px] border-[#101010] bg-[#38bdf8] shadow-[8px_8px_0_#101010]" aria-hidden="true"></div>

        <!-- Content -->
        <div class="relative z-10 max-w-[1200px] mx-auto px-6 md:px-8">
            <div
                class="md:grid md:grid-cols-2 md:gap-12 lg:gap-16 items-center"
            >
                <!-- Left Column -->
                <div>
                    <!-- Badge -->
                    <span class="mb-4 inline-flex rotate-[-2deg] items-center border-[3px] border-[#101010] bg-white px-3 py-1 text-xs font-black uppercase text-[#101010] shadow-[4px_4px_0_#101010] animate-on-scroll">Trusted Mods</span>

                    <!-- Heading -->
                    <h1
                        class="display-font max-w-xl text-4xl text-[#101010] sm:text-5xl md:text-6xl animate-on-scroll delay-100"
                    >
                        Download <span class="text-gradient">Mod APK</span><br
                        />
                        Games &amp; Apps
                    </h1>

                    <!-- Description -->
                    <p
                        class="mt-5 max-w-lg border-l-[6px] border-[#101010] bg-white px-4 py-3 text-base font-bold text-[#101010] shadow-[5px_5px_0_#101010] animate-on-scroll delay-200"
                    >
                        Latest and trusted mod APK collection for Android.
                        Unlimited resources, premium unlocked, and much more.
                    </p>

                    <!-- CTA Buttons -->
                    <div
                        class="flex flex-wrap gap-3 mt-6 animate-on-scroll delay-300"
                    >
                        <a
                            href="/category/games"
                            class="brutal-btn px-6 py-3 font-black uppercase"
                        >
                            Browse Games
                        </a>
                        <a
                            href="/category/apps"
                            class="border-[3px] border-[#101010] bg-white px-6 py-3 font-black uppercase text-[#101010] shadow-[5px_5px_0_#101010] transition-all duration-200 hover:-translate-y-0.5 hover:bg-[#38bdf8]"
                        >
                            Browse Apps
                        </a>
                    </div>

                    <!-- Feature Pills -->
                    <div
                        class="flex flex-wrap gap-2 mt-6 animate-on-scroll delay-400"
                    >
                        <span
                            class="border-2 border-[#101010] bg-[#22c55e] px-3 py-1.5 text-xs font-black uppercase text-[#101010]"
                            >Unlimited Coins</span
                        >
                        <span
                            class="border-2 border-[#101010] bg-[#ff4fd8] px-3 py-1.5 text-xs font-black uppercase text-[#101010]"
                            >Premium Unlocked</span
                        >
                        <span
                            class="border-2 border-[#101010] bg-[#38bdf8] px-3 py-1.5 text-xs font-black uppercase text-[#101010]"
                            >Ad-Free</span
                        >
                    </div>
                </div>

                <!-- Right Column (floating cards) -->
                <div class="hidden md:block relative h-[380px]">
                    <!-- Card 1: Top Game -->
                    <div
                        class="absolute top-8 right-4 z-20 w-48 rotate-[-3deg] border-[3px] border-[#101010] bg-white p-4 shadow-[8px_8px_0_#101010] animate-on-scroll delay-200 md:w-56"
                        style="--float-rotate: -3deg; animation: float 6s ease-in-out infinite;"
                    >
                        <div class="flex items-center gap-3 mb-3">
                            <div
                                class="flex h-10 w-10 shrink-0 items-center justify-center border-2 border-[#101010] bg-[#22c55e]"
                            >
                                <svg
                                    class="h-5 w-5 text-[#101010]"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke="currentColor"
                                    stroke-width="2"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"
                                    ></path>
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                                    ></path>
                                </svg>
                            </div>
                            <div>
                                <p
                                    class="text-sm font-black leading-tight text-[#101010]"
                                >
                                    Clash of Clans
                                </p>
                                <p
                                    class="mt-0.5 inline-block bg-[#ffee32] text-[10px] font-black text-[#101010]"
                                >
                                    TOP GAME
                                </p>
                            </div>
                        </div>
                        <p class="text-xs font-bold text-[#595959]">
                            MOD: Unlimited Gems
                        </p>
                        <div class="flex items-center gap-1 mt-2">
                            <svg
                                class="h-3.5 w-3.5 text-yellow-400"
                                fill="currentColor"
                                viewBox="0 0 20 20"
                                ><path
                                    d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"
                                ></path></svg
                            >
                            <svg
                                class="h-3.5 w-3.5 text-yellow-400"
                                fill="currentColor"
                                viewBox="0 0 20 20"
                                ><path
                                    d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"
                                ></path></svg
                            >
                            <svg
                                class="h-3.5 w-3.5 text-yellow-400"
                                fill="currentColor"
                                viewBox="0 0 20 20"
                                ><path
                                    d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"
                                ></path></svg
                            >
                            <svg
                                class="h-3.5 w-3.5 text-yellow-400"
                                fill="currentColor"
                                viewBox="0 0 20 20"
                                ><path
                                    d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"
                                ></path></svg
                            >
                            <svg
                                class="h-3.5 w-3.5 text-yellow-400/40"
                                fill="currentColor"
                                viewBox="0 0 20 20"
                                ><path
                                    d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"
                                ></path></svg
                            >
                            <span class="ml-1 text-[10px] font-black text-[#101010]"
                                >4.7</span
                            >
                        </div>
                    </div>

                    <!-- Card 2: Category Grid -->
                    <div
                        class="absolute top-4 left-0 z-10 w-40 rotate-[5deg] border-[3px] border-[#101010] bg-[#38bdf8] p-3 shadow-[8px_8px_0_#101010] animate-on-scroll delay-400 md:w-44"
                        style="--float-rotate: 5deg; animation: float 7s ease-in-out 1s infinite;"
                    >
                        <p class="mb-2 text-xs font-black uppercase text-[#101010]">
                            Categories
                        </p>
                        <div class="grid grid-cols-2 gap-2">
                            <div
                                class="border-2 border-[#101010] bg-white p-2 text-center"
                            >
                                <div
                                    class="mx-auto mb-1 h-5 w-5 border-2 border-[#101010] bg-[#22c55e]"
                                >
                                </div>
                                <span class="text-[9px] font-black text-[#101010]">Games</span
                                >
                            </div>
                            <div
                                class="border-2 border-[#101010] bg-white p-2 text-center"
                            >
                                <div
                                    class="mx-auto mb-1 h-5 w-5 border-2 border-[#101010] bg-[#38bdf8]"
                                >
                                </div>
                                <span class="text-[9px] font-black text-[#101010]">Apps</span
                                >
                            </div>
                            <div
                                class="border-2 border-[#101010] bg-white p-2 text-center"
                            >
                                <div
                                    class="mx-auto mb-1 h-5 w-5 border-2 border-[#101010] bg-[#ff5a1f]"
                                >
                                </div>
                                <span class="text-[9px] font-black text-[#101010]">Tools</span
                                >
                            </div>
                            <div
                                class="border-2 border-[#101010] bg-white p-2 text-center"
                            >
                                <div
                                    class="mx-auto mb-1 h-5 w-5 border-2 border-[#101010] bg-[#ff4fd8]"
                                >
                                </div>
                                <span class="text-[9px] font-black text-[#101010]">Social</span
                                >
                            </div>
                        </div>
                    </div>

                    <!-- Card 3: Stats -->
                    <div
                        class="absolute bottom-4 left-6 z-[15] w-36 rotate-[-5deg] border-[3px] border-[#101010] bg-[#ff4fd8] p-3 shadow-[8px_8px_0_#101010] animate-on-scroll delay-500 md:w-40"
                        style="--float-rotate: -5deg; animation: float 8s ease-in-out 2s infinite;"
                    >
                        <p class="text-xs font-black text-[#101010]">8+ Apps</p>
                        <p class="mt-1 text-[10px] font-bold text-[#101010]">
                            Available now
                        </p>
                        <div
                            class="mt-2 h-2 w-full overflow-hidden border-2 border-[#101010] bg-white"
                        >
                            <div
                                class="h-full w-3/4 bg-[#ffee32]"
                            >
                            </div>
                        </div>
                    </div>

                    <!-- Decorative dots -->
                    <div
                        class="absolute top-1/3 left-8 h-4 w-4 rounded-full bg-[#68cb5b]/40 blur-sm"
                        aria-hidden="true"
                    >
                    </div>
                    <div
                        class="absolute right-12 bottom-1/3 h-3 w-3 rounded-full bg-[#f77a4c]/30 blur-sm"
                        aria-hidden="true"
                    >
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ============================================ -->
    <!-- 2. SEARCH + FILTER SECTION                   -->
    <!-- ============================================ -->
    <div class="max-w-[1200px] mx-auto px-6 md:px-8 mt-8 md:mt-12">
        <div class="animate-on-scroll">
            <SearchBar />
        </div>
        <div class="mt-4 animate-on-scroll delay-100">
            <CategoryPills activeCategory="all" />
        </div>
    </div>

    <!-- ============================================ -->
    <!-- 3. LATEST GAMES SECTION                      -->
    <!-- ============================================ -->
    <section class="max-w-[1200px] mx-auto px-6 md:px-8 mt-10 md:mt-14">
        <h2 class="display-font inline-block rotate-[-1deg] border-[3px] border-[#101010] bg-[#22c55e] px-4 py-2 text-lg uppercase text-[#101010] shadow-[5px_5px_0_#101010] animate-on-scroll md:text-xl">
            Latest Games
        </h2>
        <div
            class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4 md:gap-5 mt-5"
        >
            {gameApps.map((app) => <AppCard app={app} />)}
        </div>
        <div class="mt-6 text-center">
            <a
                href="/category/games"
                class="brutal-btn mt-6 inline-flex items-center gap-2 px-6 py-2.5 font-black uppercase"
            >
                All Games
                <svg
                    class="h-4 w-4"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                </svg>
            </a>
        </div>
    </section>

    <!-- ============================================ -->
    <!-- 4. AD PLACEHOLDER                            -->
    <!-- ============================================ -->
    <div class="max-w-[1200px] mx-auto px-6 md:px-8 mt-10">
        <div
            class="flex items-center justify-center border-[3px] border-dashed border-[#101010] bg-white py-6 text-xs font-black uppercase text-[#595959] shadow-[5px_5px_0_#101010]"
        >
            Advertisement
        </div>
    </div>

    <!-- ============================================ -->
    <!-- 5. LATEST APPS SECTION                       -->
    <!-- ============================================ -->
    <section class="max-w-[1200px] mx-auto px-6 md:px-8 mt-10">
        <h2 class="display-font inline-block rotate-[1deg] border-[3px] border-[#101010] bg-[#ff5a1f] px-4 py-2 text-lg uppercase text-[#101010] shadow-[5px_5px_0_#101010] animate-on-scroll md:text-xl">
            Latest Apps
        </h2>
        <div
            class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4 md:gap-5 mt-5"
        >
            {nonGameApps.map((app) => <AppCard app={app} />)}
        </div>
        <div class="mt-6 text-center">
            <a
                href="/category/apps"
                class="mt-6 inline-flex items-center gap-2 border-[3px] border-[#101010] bg-[#38bdf8] px-6 py-2.5 font-black uppercase text-[#101010] shadow-[5px_5px_0_#101010] transition-all duration-200 hover:-translate-y-0.5 hover:bg-[#ff4fd8]"
            >
                All Apps
                <svg
                    class="h-4 w-4"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                </svg>
            </a>
        </div>
    </section>

    <!-- ============================================ -->
    <!-- 6. ABOUT / FEATURES SECTION                  -->
    <!-- ============================================ -->
    <section
        class="relative mt-12 overflow-hidden border-t-[4px] border-[#101010] bg-[#101010] py-16 md:py-20"
    >
        <div class="absolute inset-0 opacity-20" aria-hidden="true" style="background-image: linear-gradient(45deg, #ffee32 25%, transparent 25%, transparent 50%, #ffee32 50%, #ffee32 75%, transparent 75%, transparent); background-size: 32px 32px;"></div>

        <div class="relative z-10 max-w-[1200px] mx-auto px-6 md:px-8">
            <!-- Title -->
            <div class="text-center mb-10 md:mb-14">
                <h2 class="display-font text-3xl text-white animate-on-scroll md:text-4xl">
                    Why Rrmod?
                </h2>
                <p
                    class="mx-auto mt-3 max-w-md border-[3px] border-white bg-[#ffee32] px-4 py-3 text-sm font-black text-[#101010] shadow-[6px_6px_0_white] animate-on-scroll delay-100"
                >
                    Trusted mod APK download platform with collection most
                    complete and updated.
                </p>
            </div>

            <!-- Feature Cards -->
            <div class="grid gap-5 md:grid-cols-3">
                <!-- Card 1: Verified Mods -->
                <div
                    class="border-[3px] border-white bg-white p-6 text-[#101010] shadow-[7px_7px_0_#ffee32] transition-all duration-300 hover:-translate-y-1 animate-on-scroll delay-200"
                >
                    <div
                        class="mb-4 flex h-12 w-12 items-center justify-center border-2 border-[#101010] bg-[#22c55e]"
                    >
                        <svg
                            class="h-6 w-6 text-[#101010]"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                            stroke-width="2"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
                            ></path>
                        </svg>
                    </div>
                    <h3 class="mb-2 text-base font-black text-[#101010]">
                        Verified Mods
                    </h3>
                    <p class="text-sm font-bold leading-relaxed text-[#343a40]">
                        All mods are verified and virus free. Security Your
                        device is our top priority.
                    </p>
                </div>

                <!-- Card 2: Fast Downloads -->
                <div
                    class="border-[3px] border-white bg-white p-6 text-[#101010] shadow-[7px_7px_0_#38bdf8] transition-all duration-300 hover:-translate-y-1 animate-on-scroll delay-300"
                >
                    <div
                        class="mb-4 flex h-12 w-12 items-center justify-center border-2 border-[#101010] bg-[#38bdf8]"
                    >
                        <svg
                            class="h-6 w-6 text-[#101010]"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                            stroke-width="2"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"
                            ></path>
                        </svg>
                    </div>
                    <h3 class="mb-2 text-base font-black text-[#101010]">
                        Fast Downloads
                    </h3>
                    <p class="text-sm font-bold leading-relaxed text-[#343a40]">
                        Direct download link, without excessive redirects. Get
                        your mod files in seconds.
                    </p>
                </div>

                <!-- Card 3: Always Updated -->
                <div
                    class="border-[3px] border-white bg-white p-6 text-[#101010] shadow-[7px_7px_0_#ff4fd8] transition-all duration-300 hover:-translate-y-1 animate-on-scroll delay-400"
                >
                    <div
                        class="mb-4 flex h-12 w-12 items-center justify-center border-2 border-[#101010] bg-[#ff4fd8]"
                    >
                        <svg
                            class="h-6 w-6 text-[#101010]"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                            stroke-width="2"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"
                            ></path>
                        </svg>
                    </div>
                    <h3 class="mb-2 text-base font-black text-[#101010]">
                        Always Updated
                    </h3>
                    <p class="text-sm font-bold leading-relaxed text-[#343a40]">
                        Mods are updated whenever a new version is released. You
                        always get the latest and most stable version.
                    </p>
                </div>
            </div>
        </div>
    </section>
</BaseLayout>
