---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAppBySlug } from '../../lib/apps';

export const prerender = false;

const { slug } = Astro.params;
const app = await getAppBySlug(slug);

if (!app) {
  return new Response(null, { status: 404, statusText: 'Not Found' });
}

const updatedDate = new Date(app.updatedAt).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});

const fullStars = Math.floor(app.rating);
const hasHalfStar = app.rating - fullStars >= 0.3;
const emptyStars = 5 - fullStars - (hasHalfStar ? 1 : 0);
---

<BaseLayout title={`${app.name} MOD APK - ModVault`} description={app.shortDescription}>
  <div class="max-w-[800px] mx-auto px-6 md:px-8 py-8 space-y-5">

    <!-- Breadcrumb -->
    <nav class="text-sm text-[#b2b2b2] animate-on-scroll">
      <a href="/" class="text-[#68cb5b] hover:text-[#5bb84f] transition-all duration-200 hover:underline">Home</a>
      <span class="mx-1.5">&rsaquo;</span>
      <a href={`/category/${app.category}`} class="text-[#68cb5b] hover:text-[#5bb84f] transition-all duration-200 hover:underline capitalize">{app.category}</a>
      <span class="mx-1.5">&rsaquo;</span>
      <span>{app.name}</span>
    </nav>

    <!-- App Header Card -->
    <div class="bg-white rounded-2xl p-6 shadow-sm transition-shadow duration-300 hover:shadow-md animate-on-scroll delay-100">
      <div class="flex items-start gap-5">
        <!-- Icon -->
        <img
          src={app.icon}
          alt={`${app.name} icon`}
          width="96"
          height="96"
          class="w-24 h-24 rounded-2xl flex-shrink-0"
        />
        <!-- Info -->
        <div class="flex-1 min-w-0">
          <h1 class="text-2xl font-bold text-[#151617]">{app.name}</h1>
          <p class="text-sm text-[#b2b2b2] mt-1">{app.developer}</p>

          <!-- Star Rating -->
          <div class="flex items-center gap-0.5 mt-2">
            {Array.from({ length: fullStars }).map(() => (
              <svg class="w-4 h-4 text-amber-400" viewBox="0 0 20 20" fill="currentColor">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
            {hasHalfStar && (
              <svg class="w-4 h-4 text-amber-400" viewBox="0 0 20 20">
                <defs>
                  <linearGradient id="half-star">
                    <stop offset="50%" stop-color="currentColor" />
                    <stop offset="50%" stop-color="#d1d5db" />
                  </linearGradient>
                </defs>
                <path fill="url(#half-star)" d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            )}
            {Array.from({ length: emptyStars }).map(() => (
              <svg class="w-4 h-4 text-gray-300" viewBox="0 0 20 20" fill="currentColor">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
            <span class="text-sm text-[#b2b2b2] ml-1">{app.rating}</span>
          </div>

          <!-- Meta -->
          <div class="flex items-center gap-1 mt-2 text-sm text-[#b2b2b2]">
            <span>v{app.version}</span>
            <span>&middot;</span>
            <span>{app.size}</span>
            <span>&middot;</span>
            <span>{app.requires}</span>
          </div>
        </div>
      </div>

      <!-- Download Button -->
      <a
        id="main-download-btn"
        href={`/download/${app.slug}?v=0`}
        class="mt-5 block w-full text-center py-3.5 bg-[#68cb5b] hover:bg-[#5bb84f] text-white font-bold rounded-full shadow-[0_.5rem_1.5rem_0_rgba(104,203,91,0.3)] hover:shadow-[0_.5rem_2rem_0_rgba(104,203,91,0.4)] hover:-translate-y-0.5 transition-all duration-200"
      >
        Download MOD APK
      </a>
    </div>

    <!-- Screenshots Gallery -->
    {app.screenshots && app.screenshots.length > 0 && (
      <div class="bg-white rounded-2xl p-6 shadow-sm transition-shadow duration-300 hover:shadow-md animate-on-scroll delay-125">
        <h2 class="text-lg font-bold text-[#151617] mb-4">Screenshots</h2>
        <div class="relative">
          <div id="screenshot-gallery" class="flex gap-3 overflow-x-auto scroll-smooth pb-3 snap-x snap-mandatory" style="scrollbar-width: thin; scrollbar-color: #d5d7d3 transparent;">
            {app.screenshots.map((src, i) => (
              <img
                src={src}
                alt={`${app.name} screenshot ${i + 1}`}
                loading="lazy"
                class="screenshot-img h-52 sm:h-64 w-auto rounded-xl flex-shrink-0 snap-start cursor-pointer object-cover border border-[#edefec] hover:border-[#68cb5b] transition-all duration-200 hover:shadow-md"
                data-index={i}
              />
            ))}
          </div>
        </div>
      </div>
    )}

    <!-- Screenshot Lightbox -->
    <div id="screenshot-lightbox" class="fixed inset-0 z-50 bg-black/80 backdrop-blur-sm hidden items-center justify-center p-4">
      <button id="lightbox-close" class="absolute top-4 right-4 w-10 h-10 rounded-full bg-white/10 hover:bg-white/20 text-white flex items-center justify-center transition-colors cursor-pointer">
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
      <button id="lightbox-prev" class="absolute left-3 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-white/10 hover:bg-white/20 text-white flex items-center justify-center transition-colors cursor-pointer">
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
      </button>
      <button id="lightbox-next" class="absolute right-3 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-white/10 hover:bg-white/20 text-white flex items-center justify-center transition-colors cursor-pointer">
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </button>
      <img id="lightbox-img" src="" alt="" class="max-h-[85vh] max-w-[90vw] rounded-xl object-contain" />
      <div id="lightbox-counter" class="absolute bottom-4 left-1/2 -translate-x-1/2 text-white/70 text-sm font-medium"></div>
    </div>

    <!-- Version Selector Card -->
    <div class="bg-white rounded-2xl p-6 shadow-sm transition-shadow duration-300 hover:shadow-md animate-on-scroll delay-150">
      <h2 class="text-lg font-bold text-[#151617] mb-1">Available Versions</h2>
      <p class="text-sm text-[#b2b2b2] mb-4">Each version has its own download link</p>
      
      <div class="space-y-3" id="version-list">
        {(app.versions || []).map((ver, i) => (
          <div class={`flex items-center gap-4 p-4 rounded-xl border-2 transition-all duration-200 ${ver.isLatest ? 'border-[#68cb5b] bg-[#68cb5b]/5' : 'border-[#edefec]'}`}>
            <!-- Version info -->
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 flex-wrap">
                <span class="text-sm font-bold text-[#151617]">{ver.label}</span>
                {ver.isLatest && (
                  <span class="text-[10px] font-bold bg-[#68cb5b] text-white px-2 py-0.5 rounded-full">LATEST</span>
                )}
              </div>
              <div class="flex items-center gap-2 mt-1 text-xs text-[#b2b2b2]">
                <span>{ver.size}</span>
                <span>&middot;</span>
                <span>{ver.modType}</span>
              </div>
            </div>
            
            <!-- Download button per version -->
            <a
              href={`/download/${app.slug}?v=${i}`}
              class="flex items-center gap-1.5 px-4 py-2 rounded-full bg-[#68cb5b] hover:bg-[#5bb84f] text-white text-xs font-bold shrink-0 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-200"
            >
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
              </svg>
              Download
            </a>
          </div>
        ))}
      </div>
      
      <!-- If no versions array, show single download -->
      {(!app.versions || app.versions.length === 0) && (
        <p class="text-sm text-[#b2b2b2] italic">Only one version available.</p>
      )}
    </div>

    <!-- Mod Features Card -->
    <div class="bg-white rounded-2xl p-6 shadow-sm transition-shadow duration-300 hover:shadow-md animate-on-scroll delay-200">
      <h2 class="text-lg font-bold text-[#151617] mb-4">Mod Features</h2>
      <ul class="space-y-2.5">
        {app.modFeatures.map((feature) => (
          <li class="flex items-center gap-2.5 text-sm text-[#343a40]">
            <svg class="w-5 h-5 text-[#68cb5b] flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
            <span>{feature}</span>
          </li>
        ))}
      </ul>
    </div>

    <!-- Description Card -->
    <div class="bg-white rounded-2xl p-6 shadow-sm transition-shadow duration-300 hover:shadow-md animate-on-scroll delay-300">
      <h2 class="text-lg font-bold text-[#151617] mb-4">Description</h2>
      <p class="text-sm text-[#343a40] leading-relaxed whitespace-pre-line">{app.fullDescription}</p>
    </div>

    <!-- Info Grid Card -->
    <div class="bg-white rounded-2xl p-6 shadow-sm transition-shadow duration-300 hover:shadow-md animate-on-scroll delay-[400ms]">
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-5">
        <div>
          <span class="text-xs text-[#b2b2b2] uppercase tracking-wide">Category</span>
          <p class="text-sm font-bold text-[#151617] mt-0.5 capitalize">{app.category}</p>
        </div>
        <div>
          <span class="text-xs text-[#b2b2b2] uppercase tracking-wide">Version</span>
          <p class="text-sm font-bold text-[#151617] mt-0.5">{app.version}</p>
        </div>
        <div>
          <span class="text-xs text-[#b2b2b2] uppercase tracking-wide">Size</span>
          <p class="text-sm font-bold text-[#151617] mt-0.5">{app.size}</p>
        </div>
        <div>
          <span class="text-xs text-[#b2b2b2] uppercase tracking-wide">Requires</span>
          <p class="text-sm font-bold text-[#151617] mt-0.5">{app.requires}</p>
        </div>
        <div>
          <span class="text-xs text-[#b2b2b2] uppercase tracking-wide">Updated</span>
          <p class="text-sm font-bold text-[#151617] mt-0.5">{updatedDate}</p>
        </div>
      </div>
    </div>

    <!-- Ad Placeholder -->
    <div class="bg-[#edefec] rounded-2xl p-8 text-center text-sm text-[#b2b2b2] border border-dashed border-[#d5d7d3]">
      Ad Placeholder
    </div>

  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      // Screenshot Lightbox
      const lightbox = document.getElementById('screenshot-lightbox');
      const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
      const lightboxCounter = document.getElementById('lightbox-counter');
      const screenshots = document.querySelectorAll('.screenshot-img');
      let currentIndex = 0;

      function openLightbox(index: number) {
        currentIndex = index;
        const img = screenshots[index] as HTMLImageElement;
        if (lightboxImg) lightboxImg.src = img.src;
        if (lightboxCounter) lightboxCounter.textContent = `${index + 1} / ${screenshots.length}`;
        lightbox?.classList.remove('hidden');
        lightbox?.classList.add('flex');
      }

      function closeLightbox() {
        lightbox?.classList.add('hidden');
        lightbox?.classList.remove('flex');
      }

      function navigate(dir: number) {
        currentIndex = (currentIndex + dir + screenshots.length) % screenshots.length;
        const img = screenshots[currentIndex] as HTMLImageElement;
        if (lightboxImg) lightboxImg.src = img.src;
        if (lightboxCounter) lightboxCounter.textContent = `${currentIndex + 1} / ${screenshots.length}`;
      }

      screenshots.forEach((img, i) => {
        img.addEventListener('click', () => openLightbox(i));
      });

      document.getElementById('lightbox-close')?.addEventListener('click', closeLightbox);
      document.getElementById('lightbox-prev')?.addEventListener('click', () => navigate(-1));
      document.getElementById('lightbox-next')?.addEventListener('click', () => navigate(1));

      lightbox?.addEventListener('click', (e) => {
        if (e.target === lightbox) closeLightbox();
      });

      document.addEventListener('keydown', (e) => {
        if (lightbox?.classList.contains('hidden')) return;
        if (e.key === 'Escape') closeLightbox();
        if (e.key === 'ArrowLeft') navigate(-1);
        if (e.key === 'ArrowRight') navigate(1);
      });

      // Version selector radio logic removed — each version now has its own download link
    });
  </script>
</BaseLayout>
