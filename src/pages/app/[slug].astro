---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAppBySlug } from '../../lib/apps';

export const prerender = false;

const { slug } = Astro.params;
const app = await getAppBySlug(slug);

if (!app) {
  return new Response(null, { status: 404, statusText: 'Not Found' });
}

const updatedDate = new Date(app.updatedAt).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});

const fullStars = Math.floor(app.rating);
const hasHalfStar = app.rating - fullStars >= 0.3;
const emptyStars = 5 - fullStars - (hasHalfStar ? 1 : 0);
---

<BaseLayout title={`${app.name} MOD APK - Rrmod`} description={app.shortDescription}>
  <div class="mx-auto max-w-[850px] space-y-6 px-6 py-10 md:px-8">

    <!-- Breadcrumb -->
    <nav class="text-sm font-black text-[#595959] animate-on-scroll">
      <a href="/" class="bg-[#ffee32] px-1 text-[#101010] transition-all duration-200 hover:bg-[#ff4fd8]">Home</a>
      <span class="mx-1.5">&rsaquo;</span>
      <a href={`/category/${app.category}`} class="bg-[#ffee32] px-1 text-[#101010] transition-all duration-200 hover:bg-[#ff4fd8] capitalize">{app.category}</a>
      <span class="mx-1.5">&rsaquo;</span>
      <span>{app.name}</span>
    </nav>

    <!-- App Header Card -->
    <div class="brutal-card brutal-card-hover p-6 animate-on-scroll delay-100">
      <div class="flex items-start gap-5">
        <!-- Icon -->
        <img
          src={app.icon}
          alt={`${app.name} icon`}
          width="96"
          height="96"
          class="h-24 w-24 flex-shrink-0 border-[3px] border-[#101010] object-cover shadow-[5px_5px_0_#101010]"
        />
        <!-- Info -->
        <div class="flex-1 min-w-0">
          <h1 class="display-font text-2xl text-[#101010]">{app.name}</h1>
          <p class="mt-1 text-sm font-bold text-[#595959]">{app.developer}</p>

          <!-- Star Rating -->
          <div class="flex items-center gap-0.5 mt-2">
            {Array.from({ length: fullStars }).map(() => (
              <svg class="w-4 h-4 text-amber-400" viewBox="0 0 20 20" fill="currentColor">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
            {hasHalfStar && (
              <svg class="w-4 h-4 text-amber-400" viewBox="0 0 20 20">
                <defs>
                  <linearGradient id="half-star">
                    <stop offset="50%" stop-color="currentColor" />
                    <stop offset="50%" stop-color="#d1d5db" />
                  </linearGradient>
                </defs>
                <path fill="url(#half-star)" d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            )}
            {Array.from({ length: emptyStars }).map(() => (
              <svg class="w-4 h-4 text-gray-300" viewBox="0 0 20 20" fill="currentColor">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
            <span class="ml-1 border-2 border-[#101010] bg-[#ffee32] px-1.5 text-sm font-black text-[#101010]">{app.rating}</span>
          </div>

          <!-- Meta -->
          <div class="mt-3 flex flex-wrap items-center gap-1 text-sm font-black text-[#101010]">
            <span>v{app.version}</span>
            <span>&middot;</span>
            <span>{app.size}</span>
            <span>&middot;</span>
            <span>{app.requires}</span>
          </div>
        </div>
      </div>

      <!-- Download Button -->
      <a
        id="main-download-btn"
        href={`/download/${app.slug}?v=0`}
        class="brutal-btn mt-5 block w-full py-3.5 text-center text-lg font-black uppercase"
      >
        Download MOD APK
      </a>
    </div>

    <!-- Screenshots Gallery -->
    {app.screenshots && app.screenshots.length > 0 && (
      <div class="brutal-card p-6 animate-on-scroll delay-125">
        <h2 class="display-font mb-4 text-lg text-[#101010]">Screenshots</h2>
        <div class="relative">
          <div id="screenshot-gallery" class="flex gap-3 overflow-x-auto scroll-smooth pb-3 snap-x snap-mandatory" style="scrollbar-width: thin; scrollbar-color: #d5d7d3 transparent;">
            {app.screenshots.map((src, i) => (
              <img
                src={src}
                alt={`${app.name} screenshot ${i + 1}`}
                loading="lazy"
                class="screenshot-img h-52 w-auto flex-shrink-0 snap-start cursor-pointer border-[3px] border-[#101010] object-cover transition-all duration-200 hover:-translate-y-0.5 hover:shadow-[5px_5px_0_#101010] sm:h-64"
                data-index={i}
              />
            ))}
          </div>
        </div>
      </div>
    )}

    <!-- Screenshot Lightbox -->
    <div id="screenshot-lightbox" class="fixed inset-0 z-50 bg-black/80 backdrop-blur-sm hidden items-center justify-center p-4">
      <button id="lightbox-close" class="absolute right-4 top-4 flex h-10 w-10 cursor-pointer items-center justify-center border-2 border-white bg-[#ff4fd8] text-[#101010] shadow-[4px_4px_0_white] transition-colors hover:bg-[#ffee32]">
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
      <button id="lightbox-prev" class="absolute left-3 top-1/2 flex h-10 w-10 -translate-y-1/2 cursor-pointer items-center justify-center border-2 border-white bg-[#38bdf8] text-[#101010] shadow-[4px_4px_0_white] transition-colors hover:bg-[#ffee32]">
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
      </button>
      <button id="lightbox-next" class="absolute right-3 top-1/2 flex h-10 w-10 -translate-y-1/2 cursor-pointer items-center justify-center border-2 border-white bg-[#38bdf8] text-[#101010] shadow-[4px_4px_0_white] transition-colors hover:bg-[#ffee32]">
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </button>
      <img id="lightbox-img" src="" alt="" class="max-h-[85vh] max-w-[90vw] border-[4px] border-white object-contain" />
      <div id="lightbox-counter" class="absolute bottom-4 left-1/2 -translate-x-1/2 text-white/70 text-sm font-medium"></div>
    </div>

    <!-- Version Selector Card -->
    <div class="brutal-card p-6 animate-on-scroll delay-150">
      <h2 class="display-font mb-1 text-lg text-[#101010]">Available Versions</h2>
      <p class="mb-4 text-sm font-bold text-[#595959]">Each version has its own download link</p>
      
      <div class="space-y-3" id="version-list">
        {(app.versions || []).map((ver, i) => (
          <a
            href={`/download/${app.slug}?v=${i}`}
            class={`group flex cursor-pointer items-center gap-4 border-[3px] border-[#101010] p-4 transition-all duration-200 hover:-translate-y-1 hover:shadow-[6px_6px_0_#101010] ${ver.isLatest ? 'bg-[#ffee32]' : 'bg-white hover:bg-[#38bdf8]'}`}
          >
            <!-- Version info -->
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 flex-wrap">
                <span class="text-sm font-black text-[#101010] transition-colors duration-200">{ver.label}</span>
                {ver.isLatest && (
                  <span class="border-2 border-[#101010] bg-[#22c55e] px-2 py-0.5 text-[10px] font-black text-[#101010]">LATEST</span>
                )}
              </div>
              <div class="mt-1 flex items-center gap-2 text-xs font-bold text-[#595959]">
                <span>{ver.size}</span>
                <span>&middot;</span>
                <span>{ver.modType}</span>
              </div>
            </div>
            
            <!-- Download arrow icon -->
            <div class="flex h-9 w-9 shrink-0 items-center justify-center border-2 border-[#101010] bg-[#22c55e] text-[#101010] shadow-[3px_3px_0_#101010] transition-all duration-200 group-hover:bg-[#ffee32]">
              <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-y-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
              </svg>
            </div>
          </a>
        ))}
      </div>
      
      <!-- If no versions array, show single download -->
      {(!app.versions || app.versions.length === 0) && (
        <p class="text-sm font-bold italic text-[#595959]">Only one version available.</p>
      )}
    </div>

    <!-- Mod Features Card -->
    <div class="brutal-card p-6 animate-on-scroll delay-200">
      <h2 class="display-font mb-4 text-lg text-[#101010]">Mod Features</h2>
      <ul class="space-y-2.5">
        {app.modFeatures.map((feature) => (
          <li class="flex items-center gap-2.5 text-sm font-bold text-[#343a40]">
            <svg class="h-5 w-5 flex-shrink-0 border-2 border-[#101010] bg-[#22c55e] text-[#101010]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
            <span>{feature}</span>
          </li>
        ))}
      </ul>
    </div>

    <!-- Description Card -->
    <div class="brutal-card p-6 animate-on-scroll delay-300">
      <h2 class="display-font mb-4 text-lg text-[#101010]">Description</h2>
      <p class="whitespace-pre-line text-sm font-bold leading-relaxed text-[#343a40]">{app.fullDescription}</p>
    </div>

    <!-- Info Grid Card -->
    <div class="brutal-card p-6 animate-on-scroll delay-[400ms]">
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-5">
        <div>
          <span class="text-xs font-black uppercase text-[#595959]">Category</span>
          <p class="mt-0.5 text-sm font-black capitalize text-[#101010]">{app.category}</p>
        </div>
        <div>
          <span class="text-xs font-black uppercase text-[#595959]">Version</span>
          <p class="mt-0.5 text-sm font-black text-[#101010]">{app.version}</p>
        </div>
        <div>
          <span class="text-xs font-black uppercase text-[#595959]">Size</span>
          <p class="mt-0.5 text-sm font-black text-[#101010]">{app.size}</p>
        </div>
        <div>
          <span class="text-xs font-black uppercase text-[#595959]">Requires</span>
          <p class="mt-0.5 text-sm font-black text-[#101010]">{app.requires}</p>
        </div>
        <div>
          <span class="text-xs font-black uppercase text-[#595959]">Updated</span>
          <p class="mt-0.5 text-sm font-black text-[#101010]">{updatedDate}</p>
        </div>
      </div>
    </div>

    <!-- Ad Placeholder -->
    <div class="border-[3px] border-dashed border-[#101010] bg-white p-8 text-center text-sm font-black uppercase text-[#595959] shadow-[5px_5px_0_#101010]">
      Ad Placeholder
    </div>

  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      // Screenshot Lightbox
      const lightbox = document.getElementById('screenshot-lightbox');
      const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
      const lightboxCounter = document.getElementById('lightbox-counter');
      const screenshots = document.querySelectorAll('.screenshot-img');
      let currentIndex = 0;

      function openLightbox(index: number) {
        currentIndex = index;
        const img = screenshots[index] as HTMLImageElement;
        if (lightboxImg) lightboxImg.src = img.src;
        if (lightboxCounter) lightboxCounter.textContent = `${index + 1} / ${screenshots.length}`;
        lightbox?.classList.remove('hidden');
        lightbox?.classList.add('flex');
      }

      function closeLightbox() {
        lightbox?.classList.add('hidden');
        lightbox?.classList.remove('flex');
      }

      function navigate(dir: number) {
        currentIndex = (currentIndex + dir + screenshots.length) % screenshots.length;
        const img = screenshots[currentIndex] as HTMLImageElement;
        if (lightboxImg) lightboxImg.src = img.src;
        if (lightboxCounter) lightboxCounter.textContent = `${currentIndex + 1} / ${screenshots.length}`;
      }

      screenshots.forEach((img, i) => {
        img.addEventListener('click', () => openLightbox(i));
      });

      document.getElementById('lightbox-close')?.addEventListener('click', closeLightbox);
      document.getElementById('lightbox-prev')?.addEventListener('click', () => navigate(-1));
      document.getElementById('lightbox-next')?.addEventListener('click', () => navigate(1));

      lightbox?.addEventListener('click', (e) => {
        if (e.target === lightbox) closeLightbox();
      });

      document.addEventListener('keydown', (e) => {
        if (lightbox?.classList.contains('hidden')) return;
        if (e.key === 'Escape') closeLightbox();
        if (e.key === 'ArrowLeft') navigate(-1);
        if (e.key === 'ArrowRight') navigate(1);
      });

      // Version selector radio logic removed — each version now has its own download link
    });
  </script>
</BaseLayout>
