---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAppBySlug } from '../../lib/apps';

export const prerender = false;

const { slug } = Astro.params;
const app = await getAppBySlug(slug);

if (!app) {
  return new Response(null, { status: 404, statusText: 'Not Found' });
}

const url = new URL(Astro.request.url);
const versionIndex = parseInt(url.searchParams.get('v') || '0');
const versions = app.versions || [];
const selectedVersion = versions[versionIndex] || versions[0] || null;

// Use selected version data if available, otherwise fall back to app-level data
const displayVersion = selectedVersion ? selectedVersion.version : app.version;
const displaySize = selectedVersion ? selectedVersion.size : app.size;
const displayModType = selectedVersion ? selectedVersion.modType : 'Full Mod';
const displayLabel = selectedVersion ? selectedVersion.label : `v${app.version}`;
const downloadUrl = selectedVersion ? selectedVersion.downloadUrl : app.downloadUrl;
---

<BaseLayout title={`Download ${app.name} - ModVault`} description={`Download ${app.name} MOD APK ${displayVersion} - ${app.modInfo}`}>
  <div class="max-w-lg mx-auto px-6 md:px-8 py-16 text-center">

    <!-- App Icon with MOD Badge -->
    <div class="relative inline-block animate-on-scroll">
      <img
        src={app.icon}
        alt={`${app.name} icon`}
        width="80"
        height="80"
        class="w-20 h-20 rounded-2xl mx-auto"
      />
      <span class="absolute -bottom-1 left-1/2 -translate-x-1/2 bg-[#68cb5b] text-white text-[10px] font-bold rounded-full px-2.5 py-0.5 shadow-sm">
        MOD
      </span>
    </div>

    <!-- App Name + Version -->
    <div class="animate-on-scroll delay-100">
      <h1 class="text-xl font-bold text-[#151617] mt-5">{app.name}</h1>
      <p class="text-sm text-[#b2b2b2] mt-1">{displayLabel} &middot; {displaySize} &middot; {displayModType}</p>
    </div>

    <!-- Other Versions Link -->
    {versions.length > 1 && (
      <div class="animate-on-scroll delay-100 mt-2">
        <a
          href={`/app/${slug}#version-list`}
          class="text-xs text-[#68cb5b] hover:text-[#5bb84f] underline underline-offset-2 transition-colors duration-200"
        >
          Other versions available &rarr;
        </a>
      </div>
    )}

    <!-- Countdown Section -->
    <div id="countdown-section" class="mt-10 animate-on-scroll delay-200">
      <p class="text-lg text-[#343a40]">
        Your download will start in <span id="countdown-number" class="text-[#68cb5b] font-bold text-2xl animate-pulse">10</span> seconds
      </p>
      <div class="mt-5 bg-[#edefec] rounded-full h-2.5 overflow-hidden">
        <div
          id="progress-bar"
          class="bg-[#68cb5b] h-2.5 rounded-full transition-all duration-1000 ease-linear"
          style="width: 0%"
        ></div>
      </div>
    </div>

    <!-- Download Button (hidden initially) -->
    <div id="download-section" class="mt-10 hidden">
      <a
        href={downloadUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="block w-full py-4 bg-[#68cb5b] hover:bg-[#5bb84f] text-white font-bold text-lg rounded-full shadow-[0_.5rem_1.5rem_0_rgba(104,203,91,0.3)] hover:shadow-[0_.5rem_2rem_0_rgba(104,203,91,0.4)] hover:-translate-y-0.5 transition-all duration-200"
      >
        Download Now
      </a>

      <!-- Mod Type Badge -->
      <div class="mt-4 inline-flex items-center gap-2 bg-[#68cb5b]/10 text-[#68cb5b] text-xs font-bold px-3 py-1.5 rounded-full">
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        {displayModType}
      </div>
    </div>

    <!-- Disclaimer -->
    <p class="mt-10 text-xs text-[#b2b2b2] leading-relaxed">
      File is hosted on third-party services. ModVault is not responsible for the content.
      Please verify the file before installing.
    </p>

    <!-- Ad Placeholder -->
    <div class="mt-10 bg-[#edefec] rounded-2xl p-8 text-sm text-[#b2b2b2] border border-dashed border-[#d5d7d3]">
      Ad Placeholder
    </div>

  </div>

  <script>
    document.addEventListener('DOMContentLoaded', function () {
      var remaining = 10;
      var countdownNumber = document.getElementById('countdown-number');
      var progressBar = document.getElementById('progress-bar');
      var countdownSection = document.getElementById('countdown-section');
      var downloadSection = document.getElementById('download-section');

      if (!countdownNumber || !progressBar || !countdownSection || !downloadSection) return;

      progressBar.style.width = '0%';

      var timer = setInterval(function () {
        remaining--;
        var progress = ((10 - remaining) / 10) * 100;

        countdownNumber.textContent = remaining;
        progressBar.style.width = progress + '%';

        if (remaining <= 0) {
          clearInterval(timer);
          countdownSection.classList.add('hidden');
          downloadSection.classList.remove('hidden');
          
          // Track download event
          var slug = window.location.pathname.split('/download/')[1];
          if (slug) {
            fetch('/api/track/download', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ appSlug: slug, versionLabel: document.title }),
            }).catch(function() {});
          }
        }
      }, 1000);
    });
  </script>
</BaseLayout>
