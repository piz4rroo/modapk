---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAppBySlug } from '../../lib/apps';

export const prerender = false;

const { slug } = Astro.params;
const app = await getAppBySlug(slug);

if (!app) {
  return new Response(null, { status: 404, statusText: 'Not Found' });
}

const url = new URL(Astro.request.url);
const versionIndex = parseInt(url.searchParams.get('v') || '0');
const versions = app.versions || [];
const selectedVersion = versions[versionIndex] || versions[0] || null;

// Use selected version data if available, otherwise fall back to app-level data
const displayVersion = selectedVersion ? selectedVersion.version : app.version;
const displaySize = selectedVersion ? selectedVersion.size : app.size;
const displayModType = selectedVersion ? selectedVersion.modType : 'Full Mod';
const displayLabel = selectedVersion ? selectedVersion.label : `v${app.version}`;
const downloadUrl = selectedVersion ? selectedVersion.downloadUrl : app.downloadUrl;
---

<BaseLayout title={`Download ${app.name} - Rrmod`} description={`Download ${app.name} MOD APK ${displayVersion} - ${app.modFeatures[0] || app.shortDescription}`}>
  <div class="mx-auto max-w-lg px-6 py-16 text-center md:px-8">

    <!-- App Icon with MOD Badge -->
    <div class="relative inline-block animate-on-scroll">
      <img
        src={app.icon}
        alt={`${app.name} icon`}
        width="80"
        height="80"
        class="mx-auto h-20 w-20 border-[3px] border-[#101010] object-cover shadow-[5px_5px_0_#101010]"
      />
      <span class="absolute -bottom-2 left-1/2 -translate-x-1/2 border-2 border-[#101010] bg-[#ff4fd8] px-2.5 py-0.5 text-[10px] font-black text-[#101010] shadow-[3px_3px_0_#101010]">
        MOD
      </span>
    </div>

    <!-- App Name + Version -->
    <div class="animate-on-scroll delay-100">
      <h1 class="display-font mt-6 text-2xl text-[#101010]">{app.name}</h1>
      <p class="mt-2 border-[3px] border-[#101010] bg-white px-3 py-2 text-sm font-black text-[#101010] shadow-[5px_5px_0_#101010]">{displayLabel} &middot; {displaySize} &middot; {displayModType}</p>
    </div>

    <!-- Other Versions Link -->
    {versions.length > 1 && (
      <div class="animate-on-scroll delay-100 mt-2">
        <a
          href={`/app/${slug}#version-list`}
          class="text-xs font-black text-[#101010] underline decoration-[#ff4fd8] decoration-4 underline-offset-2 transition-colors duration-200 hover:bg-[#ffee32]"
        >
          Other versions available &rarr;
        </a>
      </div>
    )}

    <!-- Countdown Section -->
    <div id="countdown-section" class="brutal-card mt-10 p-6 animate-on-scroll delay-200">
      <p class="text-lg font-black text-[#101010]">
        Your download will start in <span id="countdown-number" class="inline-block border-2 border-[#101010] bg-[#ffee32] px-2 text-2xl font-black text-[#101010] animate-pulse">10</span> seconds
      </p>
      <div class="mt-5 h-4 overflow-hidden border-[3px] border-[#101010] bg-white">
        <div
          id="progress-bar"
          class="h-full bg-[#22c55e] transition-all duration-1000 ease-linear"
          style="width: 0%"
        ></div>
      </div>
    </div>

    <!-- Download Button (hidden initially) -->
    <div id="download-section" class="mt-10 hidden">
      <a
        href={downloadUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="brutal-btn block w-full py-4 text-lg font-black uppercase"
      >
        Download Now
      </a>

      <!-- Mod Type Badge -->
      <div class="mt-5 inline-flex items-center gap-2 border-[3px] border-[#101010] bg-[#22c55e] px-3 py-1.5 text-xs font-black uppercase text-[#101010] shadow-[4px_4px_0_#101010]">
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        {displayModType}
      </div>
    </div>

    <!-- Disclaimer -->
    <p class="mt-10 border-l-[5px] border-[#101010] bg-white px-4 py-3 text-left text-xs font-bold leading-relaxed text-[#595959] shadow-[5px_5px_0_#101010]">
      File is hosted on third-party services. Rrmod is not responsible for the content.
      Please verify the file before installing.
    </p>

    <!-- Ad Placeholder -->
    <div class="mt-10 border-[3px] border-dashed border-[#101010] bg-white p-8 text-sm font-black uppercase text-[#595959] shadow-[5px_5px_0_#101010]">
      Ad Placeholder
    </div>

  </div>

  <script>
    document.addEventListener('DOMContentLoaded', function () {
      var remaining = 10;
      var countdownNumber = document.getElementById('countdown-number');
      var progressBar = document.getElementById('progress-bar');
      var countdownSection = document.getElementById('countdown-section');
      var downloadSection = document.getElementById('download-section');

      if (!countdownNumber || !progressBar || !countdownSection || !downloadSection) return;

      progressBar.style.width = '0%';

      var timer = setInterval(function () {
        remaining--;
        var progress = ((10 - remaining) / 10) * 100;

        countdownNumber.textContent = remaining;
        progressBar.style.width = progress + '%';

        if (remaining <= 0) {
          clearInterval(timer);
          countdownSection.classList.add('hidden');
          downloadSection.classList.remove('hidden');
          
          // Track download event
          var slug = window.location.pathname.split('/download/')[1];
          if (slug) {
            fetch('/api/track/download', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ appSlug: slug, versionLabel: document.title }),
            }).catch(function() {});
          }
        }
      }, 1000);
    });
  </script>
</BaseLayout>
