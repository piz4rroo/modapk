---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getAppBySlug } from '../../../lib/apps';
import { getAuthUser } from '../../../lib/auth';

const user = await getAuthUser(Astro.cookies);
if (!user) {
  return Astro.redirect('/admin/login');
}

const { slug } = Astro.params;
const isNew = slug === 'new';

let app: any = {
  slug: '',
  name: '',
  category: 'games',
  icon: '',
  version: '',
  size: '',
  rating: 4.5,
  developer: '',
  requires: 'Android 5.0+',
  downloadUrl: '',
  shortDescription: '',
  fullDescription: '',
  modFeatures: [],
  screenshots: [],
  versions: [],
};

if (!isNew) {
  const found = await getAppBySlug(slug);
  if (!found) {
    return Astro.redirect('/admin/apps');
  }
  app = found;
}

const title = isNew ? 'Add New App - ModVault' : `Edit: ${app.name} - ModVault`;
const formAction = isNew ? '/api/apps' : `/api/apps/${slug}`;
---

<AdminLayout title={title} activeNav={isNew ? 'add' : 'apps'}>

  <!-- Breadcrumb -->
  <div class="flex items-center gap-2 text-[12px] text-[#9ca3af] mb-6">
    <a href="/admin/apps" class="hover:text-[#68cb5b] transition-colors">Apps</a>
    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
    </svg>
    <span class="text-[#1a1d21] font-medium">{isNew ? 'Add New' : app.name}</span>
  </div>

  <form method="POST" action={formAction} id="app-form" class="space-y-6" novalidate>

    <!-- Basic Info Card -->
    <div class="bg-white rounded-2xl border border-[#e5e7eb]/60 shadow-[0_1px_3px_rgba(0,0,0,0.04)] p-6">
      <h3 class="text-[15px] font-bold text-[#1a1d21] mb-5 flex items-center gap-2">
        <svg class="w-5 h-5 text-[#68cb5b]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        Basic Information
      </h3>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <!-- Name -->
        <div>
          <label for="name" class="block text-[12px] font-semibold text-[#6b7280] uppercase tracking-wide mb-1.5">App Name <span class="text-red-400">*</span></label>
          <input
            type="text"
            id="name"
            name="name"
            value={app.name}
            required
            placeholder="e.g. Clash of Clans"
            class="w-full rounded-xl border border-[#e5e7eb] px-4 py-2.5 text-[13px] text-[#1a1d21] placeholder-[#c4c7cc] focus:outline-none focus:ring-2 focus:ring-[#68cb5b]/30 focus:border-[#68cb5b] transition-all"
          />
          <p id="name-error" class="text-[11px] text-red-500 mt-1 hidden">App name is required</p>
        </div>

        <!-- Slug -->
        <div>
          <label for="slug" class="block text-[12px] font-semibold text-[#6b7280] uppercase tracking-wide mb-1.5">Slug <span class="text-red-400">*</span></label>
          <input
            type="text"
            id="slug"
            name="slug"
            value={app.slug}
            required
            placeholder="e.g. clash-of-clans-mod"
            class="w-full rounded-xl border border-[#e5e7eb] px-4 py-2.5 text-[13px] text-[#1a1d21] placeholder-[#c4c7cc] focus:outline-none focus:ring-2 focus:ring-[#68cb5b]/30 focus:border-[#68cb5b] transition-all font-mono"
          />
          <p id="slug-error" class="text-[11px] text-red-500 mt-1 hidden">Slug is required and must be URL-friendly</p>
        </div>

        <!-- Category -->
        <div>
          <label for="category" class="block text-[12px] font-semibold text-[#6b7280] uppercase tracking-wide mb-1.5">Category</label>
          <select
            id="category"
            name="category"
            class="w-full rounded-xl border border-[#e5e7eb] px-4 py-2.5 text-[13px] text-[#1a1d21] bg-white focus:outline-none focus:ring-2 focus:ring-[#68cb5b]/30 focus:border-[#68cb5b] transition-all cursor-pointer"
          >
            <option value="games" selected={app.category === 'games'}>Games</option>
            <option value="apps" selected={app.category === 'apps'}>Apps</option>
            <option value="tools" selected={app.category === 'tools'}>Tools</option>
            <option value="social" selected={app.category === 'social'}>Social</option>
          </select>
        </div>

        <!-- Developer -->
        <div>
          <label for="developer" class="block text-[12px] font-semibold text-[#6b7280] uppercase tracking-wide mb-1.5">Developer</label>
          <input
            type="text"
            id="developer"
            name="developer"
            value={app.developer}
            placeholder="e.g. Supercell"
            class="w-full rounded-xl border border-[#e5e7eb] px-4 py-2.5 text-[13px] text-[#1a1d21] placeholder-[#c4c7cc] focus:outline-none focus:ring-2 focus:ring-[#68cb5b]/30 focus:border-[#68cb5b] transition-all"
          />
        </div>

        <!-- Icon URL -->
        <div class="md:col-span-2">
          <label for="icon" class="block text-[12px] font-semibold text-[#6b7280] uppercase tracking-wide mb-1.5">Icon URL</label>
          <div class="flex items-center gap-3">
            {app.icon && <img src={app.icon} alt="" class="w-10 h-10 rounded-xl border border-[#e5e7eb]" />}
            <input
              type="text"
              id="icon"
              name="icon"
              value={app.icon}
              placeholder="/icons/app.webp or https://..."
              class="flex-1 rounded-xl border border-[#e5e7eb] px-4 py-2.5 text-[13px] text-[#1a1d21] placeholder-[#c4c7cc] focus:outline-none focus:ring-2 focus:ring-[#68cb5b]/30 focus:border-[#68cb5b] transition-all"
            />
          </div>
        </div>
      </div>
    </div>

    <!-- Version & Technical Card -->
    <div class="bg-white rounded-2xl border border-[#e5e7eb]/60 shadow-[0_1px_3px_rgba(0,0,0,0.04)] p-6">
      <h3 class="text-[15px] font-bold text-[#1a1d21] mb-5 flex items-center gap-2">
        <svg class="w-5 h-5 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
        Version & Technical
      </h3>

      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-4">
        <div>
          <label for="version" class="block text-[12px] font-semibold text-[#6b7280] uppercase tracking-wide mb-1.5">Version</label>
          <input type="text" id="version" name="version" value={app.version} placeholder="1.0.0"
            class="w-full rounded-xl border border-[#e5e7eb] px-4 py-2.5 text-[13px] text-[#1a1d21] placeholder-[#c4c7cc] focus:outline-none focus:ring-2 focus:ring-[#68cb5b]/30 focus:border-[#68cb5b] transition-all" />
        </div>
        <div>
          <label for="size" class="block text-[12px] font-semibold text-[#6b7280] uppercase tracking-wide mb-1.5">Size</label>
          <input type="text" id="size" name="size" value={app.size} placeholder="100MB"
            class="w-full rounded-xl border border-[#e5e7eb] px-4 py-2.5 text-[13px] text-[#1a1d21] placeholder-[#c4c7cc] focus:outline-none focus:ring-2 focus:ring-[#68cb5b]/30 focus:border-[#68cb5b] transition-all" />
        </div>
        <div>
          <label for="rating" class="block text-[12px] font-semibold text-[#6b7280] uppercase tracking-wide mb-1.5">Rating</label>
          <input type="number" id="rating" name="rating" value={app.rating} step="0.1" min="0" max="5" placeholder="4.5"
            class="w-full rounded-xl border border-[#e5e7eb] px-4 py-2.5 text-[13px] text-[#1a1d21] placeholder-[#c4c7cc] focus:outline-none focus:ring-2 focus:ring-[#68cb5b]/30 focus:border-[#68cb5b] transition-all" />
          <p id="rating-error" class="text-[11px] text-red-500 mt-1 hidden">Rating must be between 0 and 5</p>
        </div>
        <div>
          <label for="requires" class="block text-[12px] font-semibold text-[#6b7280] uppercase tracking-wide mb-1.5">Requires</label>
          <input type="text" id="requires" name="requires" value={app.requires} placeholder="Android 5.0+"
            class="w-full rounded-xl border border-[#e5e7eb] px-4 py-2.5 text-[13px] text-[#1a1d21] placeholder-[#c4c7cc] focus:outline-none focus:ring-2 focus:ring-[#68cb5b]/30 focus:border-[#68cb5b] transition-all" />
        </div>
      </div>

      <!-- Download URL -->
      <div class="mt-4">
        <label for="downloadUrl" class="block text-[12px] font-semibold text-[#6b7280] uppercase tracking-wide mb-1.5">Download URL</label>
        <input type="text" id="downloadUrl" name="downloadUrl" value={app.downloadUrl} placeholder="https://mega.nz/file/..."
          class="w-full rounded-xl border border-[#e5e7eb] px-4 py-2.5 text-[13px] text-[#1a1d21] placeholder-[#c4c7cc] focus:outline-none focus:ring-2 focus:ring-[#68cb5b]/30 focus:border-[#68cb5b] transition-all" />
        <p id="url-error" class="text-[11px] text-red-500 mt-1 hidden">Please enter a valid URL</p>
      </div>
    </div>

    <!-- Description Card -->
    <div class="bg-white rounded-2xl border border-[#e5e7eb]/60 shadow-[0_1px_3px_rgba(0,0,0,0.04)] p-6">
      <h3 class="text-[15px] font-bold text-[#1a1d21] mb-5 flex items-center gap-2">
        <svg class="w-5 h-5 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h7" />
        </svg>
        Description
      </h3>

      <div class="space-y-4">
        <div>
          <label for="shortDescription" class="block text-[12px] font-semibold text-[#6b7280] uppercase tracking-wide mb-1.5">Short Description</label>
          <textarea id="shortDescription" name="shortDescription" rows="2" placeholder="Brief description for app cards..."
            class="w-full rounded-xl border border-[#e5e7eb] px-4 py-2.5 text-[13px] text-[#1a1d21] placeholder-[#c4c7cc] focus:outline-none focus:ring-2 focus:ring-[#68cb5b]/30 focus:border-[#68cb5b] transition-all resize-y">{app.shortDescription}</textarea>
        </div>
        <div>
          <label for="fullDescription" class="block text-[12px] font-semibold text-[#6b7280] uppercase tracking-wide mb-1.5">Full Description</label>
          <textarea id="fullDescription" name="fullDescription" rows="8" placeholder="Detailed description of the app and its mod features..."
            class="w-full rounded-xl border border-[#e5e7eb] px-4 py-2.5 text-[13px] text-[#1a1d21] placeholder-[#c4c7cc] focus:outline-none focus:ring-2 focus:ring-[#68cb5b]/30 focus:border-[#68cb5b] transition-all resize-y">{app.fullDescription}</textarea>
        </div>
      </div>
    </div>

    <!-- Mod Features Card -->
    <div class="bg-white rounded-2xl border border-[#e5e7eb]/60 shadow-[0_1px_3px_rgba(0,0,0,0.04)] p-6">
      <h3 class="text-[15px] font-bold text-[#1a1d21] mb-5 flex items-center gap-2">
        <svg class="w-5 h-5 text-[#68cb5b]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
        </svg>
        Mod Features
      </h3>

      <div id="mod-features-list" class="space-y-2 mb-3">
        {(app.modFeatures.length > 0 ? app.modFeatures : ['']).map((feature: string, i: number) => (
          <div class="flex items-center gap-2 mod-feature-item" data-index={i}>
            <svg class="w-4 h-4 text-[#9ca3af] cursor-grab drag-handle flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 8h16M4 16h16" />
            </svg>
            <input type="text" value={feature} placeholder="e.g. Unlimited Gems"
              class="mod-feature-input flex-1 rounded-lg border border-[#e5e7eb] px-3 py-2 text-[13px] text-[#1a1d21] placeholder-[#c4c7cc] focus:outline-none focus:ring-2 focus:ring-[#68cb5b]/30 focus:border-[#68cb5b] transition-all" />
            <button type="button" class="remove-feature w-7 h-7 rounded-lg flex items-center justify-center text-[#9ca3af] hover:text-red-500 hover:bg-red-50 transition-all cursor-pointer flex-shrink-0">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </button>
          </div>
        ))}
      </div>
      <button type="button" id="add-feature-btn" class="inline-flex items-center gap-1.5 text-[12px] font-semibold text-[#68cb5b] hover:text-[#5bb84f] transition-colors cursor-pointer">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
        </svg>
        Add Feature
      </button>
      <!-- Hidden textarea for form submission -->
      <textarea id="modFeatures" name="modFeatures" class="hidden">{app.modFeatures.join('\n')}</textarea>
    </div>

    <!-- Screenshots Card -->
    <div class="bg-white rounded-2xl border border-[#e5e7eb]/60 shadow-[0_1px_3px_rgba(0,0,0,0.04)] p-6">
      <h3 class="text-[15px] font-bold text-[#1a1d21] mb-5 flex items-center gap-2">
        <svg class="w-5 h-5 text-purple-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
        Screenshots
      </h3>

      <div id="screenshots-list" class="space-y-2 mb-3">
        {(app.screenshots.length > 0 ? app.screenshots : ['']).map((url: string, i: number) => (
          <div class="flex items-center gap-2 screenshot-item" data-index={i}>
            <svg class="w-4 h-4 text-[#9ca3af] cursor-grab drag-handle flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 8h16M4 16h16" />
            </svg>
            <input type="text" value={url} placeholder="https://... or /screenshots/..."
              class="screenshot-input flex-1 rounded-lg border border-[#e5e7eb] px-3 py-2 text-[13px] text-[#1a1d21] placeholder-[#c4c7cc] focus:outline-none focus:ring-2 focus:ring-[#68cb5b]/30 focus:border-[#68cb5b] transition-all" />
            <button type="button" class="remove-screenshot w-7 h-7 rounded-lg flex items-center justify-center text-[#9ca3af] hover:text-red-500 hover:bg-red-50 transition-all cursor-pointer flex-shrink-0">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </button>
          </div>
        ))}
      </div>
      <button type="button" id="add-screenshot-btn" class="inline-flex items-center gap-1.5 text-[12px] font-semibold text-[#68cb5b] hover:text-[#5bb84f] transition-colors cursor-pointer">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
        </svg>
        Add Screenshot
      </button>
      <textarea id="screenshots" name="screenshots" class="hidden">{app.screenshots.join('\n')}</textarea>
    </div>

    <!-- Versions Card -->
    <div class="bg-white rounded-2xl border border-[#e5e7eb]/60 shadow-[0_1px_3px_rgba(0,0,0,0.04)] p-6">
      <div class="flex items-center justify-between mb-5">
        <h3 class="text-[15px] font-bold text-[#1a1d21] flex items-center gap-2">
          <svg class="w-5 h-5 text-indigo-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
          </svg>
          Versions
          <span id="version-count" class="text-[11px] font-semibold bg-indigo-50 text-indigo-500 px-2 py-0.5 rounded-full">{app.versions?.length || 0}</span>
        </h3>
        <button type="button" id="add-version-btn" class="inline-flex items-center gap-1.5 px-3.5 py-2 rounded-lg text-[12px] font-semibold text-white bg-indigo-500 hover:bg-indigo-600 shadow-sm transition-all cursor-pointer">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
          </svg>
          Add Version
        </button>
      </div>

      <!-- Version List -->
      <div id="versions-list" class="space-y-3">
        {(app.versions && app.versions.length > 0) ? app.versions.map((v: any, i: number) => (
          <div class="version-card border border-[#e5e7eb] rounded-xl p-4 bg-[#fafbfc] hover:border-[#c7cad0] transition-all relative group" data-index={i}>
            {/* Header row */}
            <div class="flex items-center justify-between mb-3">
              <div class="flex items-center gap-2">
                <svg class="w-4 h-4 text-[#9ca3af] cursor-grab ver-drag-handle flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4 8h16M4 16h16" />
                </svg>
                <span class="text-[11px] font-bold text-[#9ca3af] uppercase tracking-wider">Version {i + 1}</span>
                {v.isLatest && (
                  <span class="text-[10px] font-bold bg-[#68cb5b] text-white px-2 py-0.5 rounded-full">LATEST</span>
                )}
              </div>
              <div class="flex items-center gap-1">
                <button type="button" class="ver-move-up w-7 h-7 rounded-lg flex items-center justify-center text-[#9ca3af] hover:text-indigo-500 hover:bg-indigo-50 transition-all cursor-pointer" title="Move up">
                  <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7" /></svg>
                </button>
                <button type="button" class="ver-move-down w-7 h-7 rounded-lg flex items-center justify-center text-[#9ca3af] hover:text-indigo-500 hover:bg-indigo-50 transition-all cursor-pointer" title="Move down">
                  <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
                </button>
                <button type="button" class="ver-remove w-7 h-7 rounded-lg flex items-center justify-center text-[#9ca3af] hover:text-red-500 hover:bg-red-50 transition-all cursor-pointer" title="Remove">
                  <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
                </button>
              </div>
            </div>
            {/* Fields */}
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
              <div>
                <label class="block text-[10px] font-semibold text-[#9ca3af] uppercase tracking-wider mb-1">Label</label>
                <input type="text" class="ver-label w-full rounded-lg border border-[#e5e7eb] bg-white px-3 py-2 text-[13px] text-[#1a1d21] placeholder-[#c4c7cc] focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-400 transition-all" value={v.label} placeholder="e.g. v16.386.14 (Latest)" />
              </div>
              <div>
                <label class="block text-[10px] font-semibold text-[#9ca3af] uppercase tracking-wider mb-1">Version Number</label>
                <input type="text" class="ver-version w-full rounded-lg border border-[#e5e7eb] bg-white px-3 py-2 text-[13px] text-[#1a1d21] placeholder-[#c4c7cc] focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-400 transition-all font-mono" value={v.version} placeholder="e.g. 16.386.14" />
              </div>
              <div>
                <label class="block text-[10px] font-semibold text-[#9ca3af] uppercase tracking-wider mb-1">File Size</label>
                <input type="text" class="ver-size w-full rounded-lg border border-[#e5e7eb] bg-white px-3 py-2 text-[13px] text-[#1a1d21] placeholder-[#c4c7cc] focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-400 transition-all" value={v.size} placeholder="e.g. 280MB" />
              </div>
              <div>
                <label class="block text-[10px] font-semibold text-[#9ca3af] uppercase tracking-wider mb-1">Mod Type</label>
                <select class="ver-modtype w-full rounded-lg border border-[#e5e7eb] bg-white px-3 py-2 text-[13px] text-[#1a1d21] focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-400 transition-all cursor-pointer">
                  <option value="Full Mod" selected={v.modType === 'Full Mod'}>Full Mod</option>
                  <option value="Lite Mod" selected={v.modType === 'Lite Mod'}>Lite Mod</option>
                  <option value="Root Mod" selected={v.modType === 'Root Mod'}>Root Mod</option>
                  <option value="Premium Mod" selected={v.modType === 'Premium Mod'}>Premium Mod</option>
                  <option value="Clone Mod" selected={v.modType === 'Clone Mod'}>Clone Mod</option>
                  <option value="GB Mod" selected={v.modType === 'GB Mod'}>GB Mod</option>
                </select>
              </div>
              <div class="sm:col-span-2">
                <label class="block text-[10px] font-semibold text-[#9ca3af] uppercase tracking-wider mb-1">Download URL</label>
                <input type="text" class="ver-url w-full rounded-lg border border-[#e5e7eb] bg-white px-3 py-2 text-[13px] text-[#1a1d21] placeholder-[#c4c7cc] focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-400 transition-all" value={v.downloadUrl} placeholder="https://mega.nz/file/..." />
              </div>
            </div>
            {/* Latest checkbox */}
            <div class="mt-3 flex items-center gap-2">
              <input type="checkbox" class="ver-latest w-4 h-4 rounded border-[#d1d5db] text-[#68cb5b] focus:ring-[#68cb5b]/30 cursor-pointer accent-[#68cb5b]" checked={v.isLatest} />
              <label class="text-[12px] font-medium text-[#6b7280] cursor-pointer select-none">Mark as latest version</label>
            </div>
          </div>
        )) : (
          <div id="versions-empty" class="border-2 border-dashed border-[#e5e7eb] rounded-xl py-10 text-center">
            <svg class="w-10 h-10 mx-auto text-[#d1d5db] mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
            </svg>
            <p class="text-[13px] font-medium text-[#9ca3af]">No versions added yet</p>
            <p class="text-[11px] text-[#c4c7cc] mt-1">Click "Add Version" to create the first version</p>
          </div>
        )}
      </div>

      <!-- Hidden textarea for form submission (same format as before) -->
      <textarea id="versions" name="versions" class="hidden">{app.versions ? app.versions.map((v: any) => `${v.label}|${v.version}|${v.size}|${v.downloadUrl}|${v.modType}|${v.isLatest}`).join('\n') : ''}</textarea>
    </div>

    <!-- Submit -->
    <div class="flex items-center gap-3">
      <button
        type="submit"
        class="px-8 py-3 rounded-xl text-[14px] font-bold text-white bg-[#68cb5b] hover:bg-[#5bb84f] shadow-[0_1px_3px_rgba(104,203,91,0.3)] hover:shadow-[0_4px_12px_rgba(104,203,91,0.3)] transition-all duration-200 cursor-pointer"
      >
        {isNew ? 'Create App' : 'Save Changes'}
      </button>
      <a href="/admin/apps" class="px-6 py-3 rounded-xl text-[14px] font-semibold text-[#6b7280] bg-[#f3f4f6] hover:bg-[#e5e7eb] transition-colors">
        Cancel
      </a>
    </div>
  </form>

</AdminLayout>

<script>
  // Auto-generate slug from name (only for new apps)
  const isNew = window.location.pathname.endsWith('/new');
  if (isNew) {
    const nameInput = document.getElementById('name') as HTMLInputElement;
    const slugInput = document.getElementById('slug') as HTMLInputElement;
    if (nameInput && slugInput) {
      nameInput.addEventListener('input', () => {
        slugInput.value = nameInput.value
          .toLowerCase()
          .replace(/[^a-z0-9]+/g, '-')
          .replace(/(^-|-$)/g, '')
          + '-mod';
      });
    }
  }

  // Mod Features - dynamic list
  const featuresList = document.getElementById('mod-features-list')!;
  const featuresHidden = document.getElementById('modFeatures') as HTMLTextAreaElement;
  const addFeatureBtn = document.getElementById('add-feature-btn')!;

  function createFeatureItem(value = '') {
    const div = document.createElement('div');
    div.className = 'flex items-center gap-2 mod-feature-item';
    div.innerHTML = `
      <svg class="w-4 h-4 text-[#9ca3af] cursor-grab drag-handle flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 8h16M4 16h16" />
      </svg>
      <input type="text" value="${value.replace(/"/g, '&quot;')}" placeholder="e.g. Unlimited Gems"
        class="mod-feature-input flex-1 rounded-lg border border-[#e5e7eb] px-3 py-2 text-[13px] text-[#1a1d21] placeholder-[#c4c7cc] focus:outline-none focus:ring-2 focus:ring-[#68cb5b]/30 focus:border-[#68cb5b] transition-all" />
      <button type="button" class="remove-feature w-7 h-7 rounded-lg flex items-center justify-center text-[#9ca3af] hover:text-red-500 hover:bg-red-50 transition-all cursor-pointer flex-shrink-0">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    `;
    return div;
  }

  addFeatureBtn.addEventListener('click', () => {
    featuresList.appendChild(createFeatureItem());
  });

  featuresList.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.remove-feature');
    if (btn) {
      const items = featuresList.querySelectorAll('.mod-feature-item');
      if (items.length > 1) btn.closest('.mod-feature-item')?.remove();
    }
  });

  // Screenshots - dynamic list
  const screenshotsList = document.getElementById('screenshots-list')!;
  const screenshotsHidden = document.getElementById('screenshots') as HTMLTextAreaElement;
  const addScreenshotBtn = document.getElementById('add-screenshot-btn')!;

  function createScreenshotItem(value = '') {
    const div = document.createElement('div');
    div.className = 'flex items-center gap-2 screenshot-item';
    div.innerHTML = `
      <svg class="w-4 h-4 text-[#9ca3af] cursor-grab drag-handle flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 8h16M4 16h16" />
      </svg>
      <input type="text" value="${value.replace(/"/g, '&quot;')}" placeholder="https://... or /screenshots/..."
        class="screenshot-input flex-1 rounded-lg border border-[#e5e7eb] px-3 py-2 text-[13px] text-[#1a1d21] placeholder-[#c4c7cc] focus:outline-none focus:ring-2 focus:ring-[#68cb5b]/30 focus:border-[#68cb5b] transition-all" />
      <button type="button" class="remove-screenshot w-7 h-7 rounded-lg flex items-center justify-center text-[#9ca3af] hover:text-red-500 hover:bg-red-50 transition-all cursor-pointer flex-shrink-0">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    `;
    return div;
  }

  addScreenshotBtn.addEventListener('click', () => {
    screenshotsList.appendChild(createScreenshotItem());
  });

  screenshotsList.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.remove-screenshot');
    if (btn) {
      const items = screenshotsList.querySelectorAll('.screenshot-item');
      if (items.length > 1) btn.closest('.screenshot-item')?.remove();
    }
  });

  // Drag & Drop for features and screenshots
  function enableDragDrop(container: HTMLElement, itemSelector: string) {
    let dragItem: HTMLElement | null = null;

    container.addEventListener('dragstart', (e) => {
      dragItem = (e.target as HTMLElement).closest(itemSelector) as HTMLElement;
      if (dragItem) {
        dragItem.style.opacity = '0.5';
        e.dataTransfer?.setData('text/plain', '');
      }
    });

    container.addEventListener('dragend', () => {
      if (dragItem) {
        dragItem.style.opacity = '1';
        dragItem = null;
      }
    });

    container.addEventListener('dragover', (e) => {
      e.preventDefault();
      const target = (e.target as HTMLElement).closest(itemSelector) as HTMLElement;
      if (target && target !== dragItem) {
        const rect = target.getBoundingClientRect();
        const midY = rect.top + rect.height / 2;
        if (e.clientY < midY) {
          container.insertBefore(dragItem!, target);
        } else {
          container.insertBefore(dragItem!, target.nextSibling);
        }
      }
    });

    // Make items draggable via handle
    container.querySelectorAll(itemSelector).forEach((item) => {
      (item as HTMLElement).draggable = true;
    });

    const observer = new MutationObserver(() => {
      container.querySelectorAll(itemSelector).forEach((item) => {
        (item as HTMLElement).draggable = true;
      });
    });
    observer.observe(container, { childList: true });
  }

  enableDragDrop(featuresList, '.mod-feature-item');
  enableDragDrop(screenshotsList, '.screenshot-item');

  // =============================================
  // VERSION MANAGER
  // =============================================
  const versionsList = document.getElementById('versions-list')!;
  const versionsHidden = document.getElementById('versions') as HTMLTextAreaElement;
  const addVersionBtn = document.getElementById('add-version-btn')!;
  const versionCount = document.getElementById('version-count')!;

  const modTypeOptions = ['Full Mod', 'Lite Mod', 'Root Mod', 'Premium Mod', 'Clone Mod', 'GB Mod'];

  function esc(str: string) {
    return str.replace(/"/g, '&quot;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  }

  function createVersionCard(data?: { label: string; version: string; size: string; downloadUrl: string; modType: string; isLatest: boolean }) {
    const v = data || { label: '', version: '', size: '', downloadUrl: '', modType: 'Full Mod', isLatest: false };
    const div = document.createElement('div');
    div.className = 'version-card border border-[#e5e7eb] rounded-xl p-4 bg-[#fafbfc] hover:border-[#c7cad0] transition-all relative group';

    const optionsHtml = modTypeOptions.map(opt =>
      `<option value="${opt}" ${v.modType === opt ? 'selected' : ''}>${opt}</option>`
    ).join('');

    div.innerHTML = `
      <div class="flex items-center justify-between mb-3">
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-[#9ca3af] cursor-grab ver-drag-handle flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 8h16M4 16h16" />
          </svg>
          <span class="ver-number text-[11px] font-bold text-[#9ca3af] uppercase tracking-wider">Version</span>
          ${v.isLatest ? '<span class="ver-latest-badge text-[10px] font-bold bg-[#68cb5b] text-white px-2 py-0.5 rounded-full">LATEST</span>' : ''}
        </div>
        <div class="flex items-center gap-1">
          <button type="button" class="ver-move-up w-7 h-7 rounded-lg flex items-center justify-center text-[#9ca3af] hover:text-indigo-500 hover:bg-indigo-50 transition-all cursor-pointer" title="Move up">
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7" /></svg>
          </button>
          <button type="button" class="ver-move-down w-7 h-7 rounded-lg flex items-center justify-center text-[#9ca3af] hover:text-indigo-500 hover:bg-indigo-50 transition-all cursor-pointer" title="Move down">
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
          </button>
          <button type="button" class="ver-remove w-7 h-7 rounded-lg flex items-center justify-center text-[#9ca3af] hover:text-red-500 hover:bg-red-50 transition-all cursor-pointer" title="Remove">
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
          </button>
        </div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        <div>
          <label class="block text-[10px] font-semibold text-[#9ca3af] uppercase tracking-wider mb-1">Label</label>
          <input type="text" class="ver-label w-full rounded-lg border border-[#e5e7eb] bg-white px-3 py-2 text-[13px] text-[#1a1d21] placeholder-[#c4c7cc] focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-400 transition-all" value="${esc(v.label)}" placeholder="e.g. v16.386.14 (Latest)" />
        </div>
        <div>
          <label class="block text-[10px] font-semibold text-[#9ca3af] uppercase tracking-wider mb-1">Version Number</label>
          <input type="text" class="ver-version w-full rounded-lg border border-[#e5e7eb] bg-white px-3 py-2 text-[13px] text-[#1a1d21] placeholder-[#c4c7cc] focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-400 transition-all font-mono" value="${esc(v.version)}" placeholder="e.g. 16.386.14" />
        </div>
        <div>
          <label class="block text-[10px] font-semibold text-[#9ca3af] uppercase tracking-wider mb-1">File Size</label>
          <input type="text" class="ver-size w-full rounded-lg border border-[#e5e7eb] bg-white px-3 py-2 text-[13px] text-[#1a1d21] placeholder-[#c4c7cc] focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-400 transition-all" value="${esc(v.size)}" placeholder="e.g. 280MB" />
        </div>
        <div>
          <label class="block text-[10px] font-semibold text-[#9ca3af] uppercase tracking-wider mb-1">Mod Type</label>
          <select class="ver-modtype w-full rounded-lg border border-[#e5e7eb] bg-white px-3 py-2 text-[13px] text-[#1a1d21] focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-400 transition-all cursor-pointer">
            ${optionsHtml}
          </select>
        </div>
        <div class="sm:col-span-2">
          <label class="block text-[10px] font-semibold text-[#9ca3af] uppercase tracking-wider mb-1">Download URL</label>
          <input type="text" class="ver-url w-full rounded-lg border border-[#e5e7eb] bg-white px-3 py-2 text-[13px] text-[#1a1d21] placeholder-[#c4c7cc] focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-400 transition-all" value="${esc(v.downloadUrl)}" placeholder="https://mega.nz/file/..." />
        </div>
      </div>
      <div class="mt-3 flex items-center gap-2">
        <input type="checkbox" class="ver-latest w-4 h-4 rounded border-[#d1d5db] text-[#68cb5b] focus:ring-[#68cb5b]/30 cursor-pointer accent-[#68cb5b]" ${v.isLatest ? 'checked' : ''} />
        <label class="text-[12px] font-medium text-[#6b7280] cursor-pointer select-none">Mark as latest version</label>
      </div>
    `;
    return div;
  }

  function updateVersionNumbers() {
    const cards = versionsList.querySelectorAll('.version-card');
    cards.forEach((card, i) => {
      const numEl = card.querySelector('.ver-number');
      if (numEl) numEl.textContent = `Version ${i + 1}`;
    });
    versionCount.textContent = String(cards.length);
    // Remove empty state if versions exist
    const empty = document.getElementById('versions-empty');
    if (empty && cards.length > 0) empty.remove();
  }

  // Add version
  addVersionBtn.addEventListener('click', () => {
    const empty = document.getElementById('versions-empty');
    if (empty) empty.remove();
    const card = createVersionCard();
    versionsList.appendChild(card);
    updateVersionNumbers();
    card.querySelector('.ver-label')?.focus();
    card.scrollIntoView({ behavior: 'smooth', block: 'center' });
  });

  // Delegated events for version cards
  versionsList.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    const card = target.closest('.version-card') as HTMLElement;
    if (!card) return;

    // Remove
    if (target.closest('.ver-remove')) {
      card.style.opacity = '0';
      card.style.transform = 'translateX(20px)';
      card.style.transition = 'all 0.2s ease';
      setTimeout(() => {
        card.remove();
        updateVersionNumbers();
        // Show empty state if no versions left
        if (versionsList.querySelectorAll('.version-card').length === 0) {
          versionsList.innerHTML = `
            <div id="versions-empty" class="border-2 border-dashed border-[#e5e7eb] rounded-xl py-10 text-center">
              <svg class="w-10 h-10 mx-auto text-[#d1d5db] mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
              </svg>
              <p class="text-[13px] font-medium text-[#9ca3af]">No versions added yet</p>
              <p class="text-[11px] text-[#c4c7cc] mt-1">Click "Add Version" to create the first version</p>
            </div>`;
          versionCount.textContent = '0';
        }
      }, 200);
      return;
    }

    // Move up
    if (target.closest('.ver-move-up')) {
      const prev = card.previousElementSibling;
      if (prev && prev.classList.contains('version-card')) {
        versionsList.insertBefore(card, prev);
        updateVersionNumbers();
      }
      return;
    }

    // Move down
    if (target.closest('.ver-move-down')) {
      const next = card.nextElementSibling;
      if (next && next.classList.contains('version-card')) {
        versionsList.insertBefore(next, card);
        updateVersionNumbers();
      }
      return;
    }
  });

  // Latest checkbox: only one can be checked at a time
  versionsList.addEventListener('change', (e) => {
    const target = e.target as HTMLInputElement;
    if (target.classList.contains('ver-latest') && target.checked) {
      // Uncheck all others
      versionsList.querySelectorAll('.ver-latest').forEach((cb) => {
        if (cb !== target) (cb as HTMLInputElement).checked = false;
      });
      // Update badges
      versionsList.querySelectorAll('.version-card').forEach((card) => {
        const cb = card.querySelector('.ver-latest') as HTMLInputElement;
        const existingBadge = card.querySelector('.ver-latest-badge');
        if (cb.checked && !existingBadge) {
          const badgeSpan = document.createElement('span');
          badgeSpan.className = 'ver-latest-badge text-[10px] font-bold bg-[#68cb5b] text-white px-2 py-0.5 rounded-full';
          badgeSpan.textContent = 'LATEST';
          card.querySelector('.ver-number')?.after(badgeSpan);
        } else if (!cb.checked && existingBadge) {
          existingBadge.remove();
        }
      });
    }
  });

  // Drag & drop for version cards
  enableDragDrop(versionsList, '.version-card');

  // =============================================
  // FORM SUBMISSION
  // =============================================
  const form = document.getElementById('app-form') as HTMLFormElement;
  form.addEventListener('submit', (e) => {
    // Sync mod features
    const featureInputs = featuresList.querySelectorAll('.mod-feature-input') as NodeListOf<HTMLInputElement>;
    const features = Array.from(featureInputs).map(i => i.value.trim()).filter(Boolean);
    featuresHidden.value = features.join('\n');

    // Sync screenshots
    const screenshotInputs = screenshotsList.querySelectorAll('.screenshot-input') as NodeListOf<HTMLInputElement>;
    const screenshots = Array.from(screenshotInputs).map(i => i.value.trim()).filter(Boolean);
    screenshotsHidden.value = screenshots.join('\n');

    // Sync versions: read from visual cards -> pipe-delimited format
    const versionCards = versionsList.querySelectorAll('.version-card');
    const versionLines: string[] = [];
    versionCards.forEach((card) => {
      const label = (card.querySelector('.ver-label') as HTMLInputElement)?.value.trim() || '';
      const version = (card.querySelector('.ver-version') as HTMLInputElement)?.value.trim() || '';
      const size = (card.querySelector('.ver-size') as HTMLInputElement)?.value.trim() || '';
      const url = (card.querySelector('.ver-url') as HTMLInputElement)?.value.trim() || '';
      const modType = (card.querySelector('.ver-modtype') as HTMLSelectElement)?.value || 'Full Mod';
      const isLatest = (card.querySelector('.ver-latest') as HTMLInputElement)?.checked ? 'true' : 'false';
      if (label || version) {
        versionLines.push(`${label}|${version}|${size}|${url}|${modType}|${isLatest}`);
      }
    });
    versionsHidden.value = versionLines.join('\n');

    // Validation
    let hasError = false;
    const nameInput = document.getElementById('name') as HTMLInputElement;
    const slugInput = document.getElementById('slug') as HTMLInputElement;
    const ratingInput = document.getElementById('rating') as HTMLInputElement;

    // Name
    if (!nameInput.value.trim()) {
      document.getElementById('name-error')?.classList.remove('hidden');
      nameInput.classList.add('border-red-400');
      hasError = true;
    } else {
      document.getElementById('name-error')?.classList.add('hidden');
      nameInput.classList.remove('border-red-400');
    }

    // Slug
    if (!slugInput.value.trim() || !/^[a-z0-9-]+$/.test(slugInput.value.trim())) {
      document.getElementById('slug-error')?.classList.remove('hidden');
      slugInput.classList.add('border-red-400');
      hasError = true;
    } else {
      document.getElementById('slug-error')?.classList.add('hidden');
      slugInput.classList.remove('border-red-400');
    }

    // Rating
    const rating = parseFloat(ratingInput.value);
    if (isNaN(rating) || rating < 0 || rating > 5) {
      document.getElementById('rating-error')?.classList.remove('hidden');
      ratingInput.classList.add('border-red-400');
      hasError = true;
    } else {
      document.getElementById('rating-error')?.classList.add('hidden');
      ratingInput.classList.remove('border-red-400');
    }

    if (hasError) {
      e.preventDefault();
      const firstError = form.querySelector('.border-red-400');
      firstError?.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
  });
</script>
