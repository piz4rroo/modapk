---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getAllApps } from '../../lib/apps';
import { getAuthUser } from '../../lib/auth';

const user = await getAuthUser(Astro.cookies);
if (!user) {
  return Astro.redirect('/admin/login');
}

const apps = await getAllApps();
---

<AdminLayout title="All Apps - ModVault" activeNav="apps">

  <!-- Header -->
  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6">
    <div>
      <h2 class="text-[20px] font-bold text-[#1a1d21]">All Apps</h2>
      <p class="text-[13px] text-[#6b7280] mt-0.5">{apps.length} applications published</p>
    </div>
    <a
      href="/admin/edit/new"
      class="inline-flex items-center gap-2 px-4 py-2.5 rounded-xl text-[13px] font-semibold text-white bg-[#68cb5b] hover:bg-[#5bb84f] shadow-[0_1px_3px_rgba(104,203,91,0.3)] hover:shadow-[0_4px_12px_rgba(104,203,91,0.3)] transition-all duration-200"
    >
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
      </svg>
      Add New App
    </a>
  </div>

  <!-- Search & Filter Bar -->
  <div class="flex flex-col sm:flex-row gap-3 mb-5">
    <div class="relative flex-1">
      <svg class="absolute left-3.5 top-1/2 -translate-y-1/2 w-4 h-4 text-[#9ca3af]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
      </svg>
      <input
        type="text"
        id="search-input"
        placeholder="Search apps..."
        class="w-full pl-10 pr-4 py-2.5 rounded-xl border border-[#e5e7eb] bg-white text-[13px] text-[#1a1d21] placeholder-[#9ca3af] focus:outline-none focus:ring-2 focus:ring-[#68cb5b]/30 focus:border-[#68cb5b] transition-all"
      />
    </div>
    <select
      id="category-filter"
      class="px-4 py-2.5 rounded-xl border border-[#e5e7eb] bg-white text-[13px] text-[#1a1d21] focus:outline-none focus:ring-2 focus:ring-[#68cb5b]/30 focus:border-[#68cb5b] transition-all cursor-pointer"
    >
      <option value="all">All Categories</option>
      <option value="games">Games</option>
      <option value="apps">Apps</option>
      <option value="tools">Tools</option>
      <option value="social">Social</option>
    </select>
  </div>

  <!-- Apps Table -->
  <div class="bg-white rounded-2xl border border-[#e5e7eb]/60 shadow-[0_1px_3px_rgba(0,0,0,0.04)] overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full" id="apps-table">
        <thead>
          <tr class="text-left text-[11px] font-semibold text-[#6b7280] uppercase tracking-wider border-b border-[#f3f4f6]">
            <th class="px-6 py-3.5">App</th>
            <th class="px-6 py-3.5">Category</th>
            <th class="px-6 py-3.5">Version</th>
            <th class="px-6 py-3.5">Rating</th>
            <th class="px-6 py-3.5">Updated</th>
            <th class="px-6 py-3.5 text-right">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-[#f3f4f6]" id="apps-tbody">
          {apps.map((app) => {
            const updated = new Date(app.updatedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
            return (
              <tr class="hover:bg-[#f9fafb] transition-colors app-row" data-name={app.name.toLowerCase()} data-category={app.category}>
                <td class="px-6 py-3.5">
                  <div class="flex items-center gap-3">
                    <img src={app.icon} alt="" class="w-10 h-10 rounded-xl border border-[#f3f4f6]" />
                    <div>
                      <p class="text-[13px] font-semibold text-[#1a1d21]">{app.name}</p>
                      <p class="text-[11px] text-[#9ca3af] truncate max-w-[200px]">{app.shortDescription}</p>
                    </div>
                  </div>
                </td>
                <td class="px-6 py-3.5">
                  <span class={`inline-flex items-center px-2.5 py-1 rounded-lg text-[11px] font-semibold capitalize ${
                    app.category === 'games' ? 'bg-[#68cb5b]/10 text-[#68cb5b]' :
                    app.category === 'apps' ? 'bg-blue-500/10 text-blue-600' :
                    app.category === 'social' ? 'bg-purple-500/10 text-purple-600' :
                    'bg-amber-500/10 text-amber-600'
                  }`}>{app.category}</span>
                </td>
                <td class="px-6 py-3.5 text-[13px] text-[#6b7280] font-mono">{app.version}</td>
                <td class="px-6 py-3.5">
                  <div class="flex items-center gap-1">
                    <svg class="w-3.5 h-3.5 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                    </svg>
                    <span class="text-[13px] text-[#6b7280]">{app.rating}</span>
                  </div>
                </td>
                <td class="px-6 py-3.5 text-[12px] text-[#9ca3af]">{updated}</td>
                <td class="px-6 py-3.5">
                  <div class="flex items-center justify-end gap-1">
                    <a
                      href={`/admin/edit/${app.slug}`}
                      class="w-8 h-8 rounded-lg flex items-center justify-center text-[#6b7280] hover:text-[#68cb5b] hover:bg-[#68cb5b]/10 transition-all"
                      title="Edit"
                    >
                      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                      </svg>
                    </a>
                    <button
                      class="delete-btn w-8 h-8 rounded-lg flex items-center justify-center text-[#6b7280] hover:text-red-500 hover:bg-red-50 transition-all cursor-pointer"
                      data-slug={app.slug}
                      data-name={app.name}
                      title="Delete"
                    >
                      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                      </svg>
                    </button>
                  </div>
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>

    <!-- Empty State -->
    {apps.length === 0 && (
      <div class="px-6 py-16 text-center">
        <svg class="w-12 h-12 mx-auto text-[#d1d5db] mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4" />
        </svg>
        <p class="text-[14px] font-semibold text-[#6b7280]">No apps yet</p>
        <p class="text-[12px] text-[#9ca3af] mt-1">Get started by adding your first app.</p>
        <a href="/admin/edit/new" class="inline-flex items-center gap-2 mt-4 px-4 py-2 rounded-lg text-[13px] font-semibold text-white bg-[#68cb5b] hover:bg-[#5bb84f] transition-colors">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
          </svg>
          Add First App
        </a>
      </div>
    )}
  </div>

  <!-- Delete Confirmation Modal -->
  <div id="delete-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 backdrop-blur-sm p-4">
    <div class="bg-white rounded-2xl shadow-xl max-w-sm w-full p-6">
      <div class="w-12 h-12 rounded-full bg-red-50 flex items-center justify-center mx-auto mb-4">
        <svg class="w-6 h-6 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
        </svg>
      </div>
      <h3 class="text-[16px] font-bold text-[#1a1d21] text-center">Delete App</h3>
      <p class="text-[13px] text-[#6b7280] text-center mt-2">Are you sure you want to delete <strong id="delete-app-name"></strong>? This action cannot be undone.</p>
      <div class="flex gap-3 mt-6">
        <button id="cancel-delete" class="flex-1 py-2.5 rounded-xl text-[13px] font-semibold text-[#6b7280] bg-[#f3f4f6] hover:bg-[#e5e7eb] transition-colors cursor-pointer">Cancel</button>
        <form id="delete-form" method="POST" class="flex-1">
          <input type="hidden" name="_method" value="DELETE" />
          <button type="submit" class="w-full py-2.5 rounded-xl text-[13px] font-semibold text-white bg-red-500 hover:bg-red-600 transition-colors cursor-pointer">Delete</button>
        </form>
      </div>
    </div>
  </div>

</AdminLayout>

<script>
  // Search & Filter
  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const categoryFilter = document.getElementById('category-filter') as HTMLSelectElement;
  const rows = document.querySelectorAll('.app-row');

  function filterApps() {
    const query = searchInput.value.toLowerCase();
    const category = categoryFilter.value;

    rows.forEach((row) => {
      const el = row as HTMLElement;
      const name = el.dataset.name || '';
      const cat = el.dataset.category || '';
      const matchesSearch = name.includes(query);
      const matchesCategory = category === 'all' || cat === category;
      el.style.display = matchesSearch && matchesCategory ? '' : 'none';
    });
  }

  searchInput?.addEventListener('input', filterApps);
  categoryFilter?.addEventListener('change', filterApps);

  // Delete Modal
  const deleteModal = document.getElementById('delete-modal');
  const deleteForm = document.getElementById('delete-form') as HTMLFormElement;
  const deleteAppName = document.getElementById('delete-app-name');
  const cancelDelete = document.getElementById('cancel-delete');

  document.querySelectorAll('.delete-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const el = btn as HTMLElement;
      const slug = el.dataset.slug;
      const name = el.dataset.name;
      if (deleteForm) deleteForm.action = `/api/apps/${slug}`;
      if (deleteAppName) deleteAppName.textContent = name || '';
      deleteModal?.classList.remove('hidden');
      deleteModal?.classList.add('flex');
    });
  });

  cancelDelete?.addEventListener('click', () => {
    deleteModal?.classList.add('hidden');
    deleteModal?.classList.remove('flex');
  });

  deleteModal?.addEventListener('click', (e) => {
    if (e.target === deleteModal) {
      deleteModal.classList.add('hidden');
      deleteModal.classList.remove('flex');
    }
  });
</script>
