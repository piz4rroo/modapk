---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getAllApps } from '../../lib/apps';
import { getAuthUser } from '../../lib/auth';
import { getDashboardStats, getTopDownloadedApps, getAppDownloadCount, getAppViewCount } from '../../lib/analytics';

const user = await getAuthUser(Astro.cookies);
if (!user) {
  return Astro.redirect('/admin/login');
}

const apps = await getAllApps();
const stats = await getDashboardStats(apps.length);
const topDownloads = await getTopDownloadedApps(5);

// Build a map of app details for the top downloads table
const appMap = new Map(apps.map(a => [a.slug, a]));
---

<AdminLayout title="Dashboard - Rrmod" activeNav="dashboard">

  <!-- Stats Cards -->
  <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-4 mb-8">
    
    <!-- Total Apps -->
    <div class="bg-white rounded-2xl p-5 border border-[#e5e7eb]/60 shadow-[0_1px_3px_rgba(0,0,0,0.04)]">
      <div class="flex items-center justify-between mb-3">
        <span class="text-[12px] font-semibold text-[#6b7280] uppercase tracking-wide">Total Apps</span>
        <div class="w-9 h-9 rounded-xl bg-[#68cb5b]/10 flex items-center justify-center">
          <svg class="w-[18px] h-[18px] text-[#68cb5b]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" />
          </svg>
        </div>
      </div>
      <p class="text-[28px] font-bold text-[#1a1d21] leading-none">{stats.totalApps}</p>
      <p class="text-[12px] text-[#6b7280] mt-1.5">Published applications</p>
    </div>

    <!-- Total Downloads -->
    <div class="bg-white rounded-2xl p-5 border border-[#e5e7eb]/60 shadow-[0_1px_3px_rgba(0,0,0,0.04)]">
      <div class="flex items-center justify-between mb-3">
        <span class="text-[12px] font-semibold text-[#6b7280] uppercase tracking-wide">Total Downloads</span>
        <div class="w-9 h-9 rounded-xl bg-blue-500/10 flex items-center justify-center">
          <svg class="w-[18px] h-[18px] text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
          </svg>
        </div>
      </div>
      <p class="text-[28px] font-bold text-[#1a1d21] leading-none">{stats.totalDownloads.toLocaleString()}</p>
      <div class="flex items-center gap-2 mt-1.5">
        <span class="text-[12px] font-semibold text-[#68cb5b]">+{stats.todayDownloads}</span>
        <span class="text-[12px] text-[#6b7280]">today</span>
      </div>
    </div>

    <!-- Page Views Today -->
    <div class="bg-white rounded-2xl p-5 border border-[#e5e7eb]/60 shadow-[0_1px_3px_rgba(0,0,0,0.04)]">
      <div class="flex items-center justify-between mb-3">
        <span class="text-[12px] font-semibold text-[#6b7280] uppercase tracking-wide">Views Today</span>
        <div class="w-9 h-9 rounded-xl bg-amber-500/10 flex items-center justify-center">
          <svg class="w-[18px] h-[18px] text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
          </svg>
        </div>
      </div>
      <p class="text-[28px] font-bold text-[#1a1d21] leading-none">{stats.todayPageViews.toLocaleString()}</p>
      <p class="text-[12px] text-[#6b7280] mt-1.5">Page views today</p>
    </div>

    <!-- Page Views This Month -->
    <div class="bg-white rounded-2xl p-5 border border-[#e5e7eb]/60 shadow-[0_1px_3px_rgba(0,0,0,0.04)]">
      <div class="flex items-center justify-between mb-3">
        <span class="text-[12px] font-semibold text-[#6b7280] uppercase tracking-wide">Monthly Views</span>
        <div class="w-9 h-9 rounded-xl bg-purple-500/10 flex items-center justify-center">
          <svg class="w-[18px] h-[18px] text-purple-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
          </svg>
        </div>
      </div>
      <p class="text-[28px] font-bold text-[#1a1d21] leading-none">{stats.monthPageViews.toLocaleString()}</p>
      <div class="flex items-center gap-2 mt-1.5">
        <span class="text-[12px] font-semibold text-[#68cb5b]">+{stats.monthDownloads}</span>
        <span class="text-[12px] text-[#6b7280]">downloads this month</span>
      </div>
    </div>
  </div>

  <!-- Two Column Layout -->
  <div class="grid grid-cols-1 xl:grid-cols-3 gap-6">

    <!-- Top Downloaded Apps -->
    <div class="xl:col-span-2 bg-white rounded-2xl border border-[#e5e7eb]/60 shadow-[0_1px_3px_rgba(0,0,0,0.04)]">
      <div class="flex items-center justify-between px-6 py-4 border-b border-[#e5e7eb]/60">
        <h2 class="text-[14px] font-semibold text-[#1a1d21]">Top Downloaded Apps</h2>
        <a href="/admin/apps" class="text-[12px] font-medium text-[#68cb5b] hover:text-[#5bb84f] transition-colors">View All</a>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead>
            <tr class="text-left text-[11px] font-semibold text-[#6b7280] uppercase tracking-wider">
              <th class="px-6 py-3">#</th>
              <th class="px-6 py-3">App</th>
              <th class="px-6 py-3">Category</th>
              <th class="px-6 py-3 text-right">Downloads</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-[#f3f4f6]">
            {topDownloads.length > 0 ? topDownloads.map((item, i) => {
              const app = appMap.get(item.app_slug);
              return (
                <tr class="hover:bg-[#f9fafb] transition-colors">
                  <td class="px-6 py-3.5 text-[13px] text-[#6b7280] font-medium">{i + 1}</td>
                  <td class="px-6 py-3.5">
                    <div class="flex items-center gap-3">
                      {app?.icon && <img src={app.icon} alt="" class="w-8 h-8 rounded-lg" />}
                      <div>
                        <p class="text-[13px] font-semibold text-[#1a1d21]">{app?.name || item.app_slug}</p>
                        <p class="text-[11px] text-[#9ca3af]">v{app?.version}</p>
                      </div>
                    </div>
                  </td>
                  <td class="px-6 py-3.5">
                    <span class="inline-flex items-center px-2 py-0.5 rounded-md text-[11px] font-semibold bg-[#f3f4f6] text-[#6b7280] capitalize">{app?.category}</span>
                  </td>
                  <td class="px-6 py-3.5 text-right">
                    <span class="text-[13px] font-bold text-[#1a1d21]">{item.download_count.toLocaleString()}</span>
                  </td>
                </tr>
              );
            }) : (
              <tr>
                <td colspan="4" class="px-6 py-12 text-center text-[13px] text-[#9ca3af]">
                  No download data yet. Downloads will appear here once users start downloading apps.
                </td>
              </tr>
            )}
          </tbody>
        </table>
      </div>
    </div>

    <!-- Recent Apps -->
    <div class="bg-white rounded-2xl border border-[#e5e7eb]/60 shadow-[0_1px_3px_rgba(0,0,0,0.04)]">
      <div class="flex items-center justify-between px-6 py-4 border-b border-[#e5e7eb]/60">
        <h2 class="text-[14px] font-semibold text-[#1a1d21]">Recent Apps</h2>
        <a href="/admin/edit/new" class="text-[12px] font-medium text-[#68cb5b] hover:text-[#5bb84f] transition-colors">+ Add New</a>
      </div>
      <div class="divide-y divide-[#f3f4f6]">
        {apps.slice(0, 6).map((app) => (
          <a href={`/admin/edit/${app.slug}`} class="flex items-center gap-3 px-6 py-3.5 hover:bg-[#f9fafb] transition-colors group">
            <img src={app.icon} alt="" class="w-9 h-9 rounded-lg" />
            <div class="flex-1 min-w-0">
              <p class="text-[13px] font-semibold text-[#1a1d21] group-hover:text-[#68cb5b] transition-colors truncate">{app.name}</p>
              <p class="text-[11px] text-[#9ca3af]">{app.category} &middot; v{app.version}</p>
            </div>
            <svg class="w-4 h-4 text-[#d1d5db] group-hover:text-[#68cb5b] transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        ))}
      </div>
    </div>
  </div>

</AdminLayout>
