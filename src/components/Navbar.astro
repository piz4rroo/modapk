---
const currentPath = Astro.url.pathname;

function isActive(href: string): boolean {
    if (href === "/") return currentPath === "/";
    return currentPath.startsWith(href);
}
---

<nav
    id="main-nav"
    class="fixed top-0 left-0 right-0 z-50 bg-white/80 backdrop-blur-md shadow-[0_1px_0_0_rgba(0,0,0,0.05)] transition-all duration-300"
>
    <div
        class="max-w-[1200px] mx-auto px-6 md:px-8 h-16 md:h-20 flex items-center justify-between"
    >
        <!-- Logo -->
        <a
            href="/"
            class="flex items-center gap-2.5 font-bold text-lg tracking-tight text-[#151617]"
        >
            <span
                class="inline-block w-7 h-7 rounded-lg"
                style="background: linear-gradient(135deg, #54b247 0%, #68cb5b 100%);"
                aria-hidden="true"></span>
            <span>Rrmod</span>
        </a>

        <!-- Desktop nav links -->
        <div class="hidden md:flex items-center gap-8">
            <!-- Home -->
            <a
                href="/"
                class:list={[
                    "nav-link relative flex flex-col items-center gap-1 group transition-all duration-300 hover:-translate-y-0.5",
                    isActive("/") ? "text-[#68cb5b]" : "text-[#343a40]",
                ]}
            >
                <span
                    class:list={[
                        "text-[13px] font-bold transition-colors duration-300",
                        isActive("/")
                            ? "text-[#68cb5b]"
                            : "group-hover:text-[#68cb5b]",
                    ]}>Home</span
                >
                <span class:list={["absolute -bottom-1 h-0.5 bg-[#68cb5b] rounded-full transition-all duration-300", isActive("/") ? "w-full" : "w-0 group-hover:w-full"]}></span>
            </a>

            <!-- Games -->
            <a
                href="/category/games"
                class:list={[
                    "nav-link relative flex flex-col items-center gap-1 group transition-all duration-300 hover:-translate-y-0.5",
                    isActive("/category/games")
                        ? "text-[#68cb5b]"
                        : "text-[#343a40]",
                ]}
            >
                <span
                    class:list={[
                        "text-[13px] font-bold transition-colors duration-300",
                        isActive("/category/games")
                            ? "text-[#68cb5b]"
                            : "group-hover:text-[#68cb5b]",
                    ]}>Games</span
                >
                <span class:list={["absolute -bottom-1 h-0.5 bg-[#68cb5b] rounded-full transition-all duration-300", isActive("/category/games") ? "w-full" : "w-0 group-hover:w-full"]}></span>
            </a>

            <!-- Apps -->
            <a
                href="/category/apps"
                class:list={[
                    "nav-link relative flex flex-col items-center gap-1 group transition-all duration-300 hover:-translate-y-0.5",
                    isActive("/category/apps")
                        ? "text-[#68cb5b]"
                        : "text-[#343a40]",
                ]}
            >
                <span
                    class:list={[
                        "text-[13px] font-bold transition-colors duration-300",
                        isActive("/category/apps")
                            ? "text-[#68cb5b]"
                            : "group-hover:text-[#68cb5b]",
                    ]}>Apps</span
                >
                <span class:list={["absolute -bottom-1 h-0.5 bg-[#68cb5b] rounded-full transition-all duration-300", isActive("/category/apps") ? "w-full" : "w-0 group-hover:w-full"]}></span>
            </a>

            <!-- Tools -->
            <a
                href="/category/tools"
                class:list={[
                    "nav-link relative flex flex-col items-center gap-1 group transition-all duration-300 hover:-translate-y-0.5",
                    isActive("/category/tools")
                        ? "text-[#68cb5b]"
                        : "text-[#343a40]",
                ]}
            >
                <span
                    class:list={[
                        "text-[13px] font-bold transition-colors duration-300",
                        isActive("/category/tools")
                            ? "text-[#68cb5b]"
                            : "group-hover:text-[#68cb5b]",
                    ]}>Tools</span
                >
                <span class:list={["absolute -bottom-1 h-0.5 bg-[#68cb5b] rounded-full transition-all duration-300", isActive("/category/tools") ? "w-full" : "w-0 group-hover:w-full"]}></span>
            </a>

            <!-- Search button -->
            <button
                id="search-btn"
                class="ml-2 text-[#343a40] hover:text-[#68cb5b] transition-all duration-300 hover:scale-110 hover:-translate-y-0.5"
                aria-label="Search"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-5 h-5"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                >
                    <circle cx="11" cy="11" r="8"></circle>
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M21 21l-4.35-4.35"></path>
                </svg>
            </button>
        </div>

        <!-- Mobile hamburger -->
        <button
            id="menu-toggle"
            class="md:hidden text-[#343a40] hover:text-[#68cb5b] transition-colors duration-200"
            aria-label="Toggle menu"
            aria-expanded="false"
        >
            <svg
                id="icon-hamburger"
                xmlns="http://www.w3.org/2000/svg"
                class="w-6 h-6"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
        </button>
    </div>
</nav>

<!-- Mobile slide-in drawer overlay -->
<div
    id="mobile-overlay"
    class="fixed inset-0 z-[60] bg-black/50 opacity-0 pointer-events-none transition-opacity duration-200 md:hidden"
>
</div>

<!-- Mobile slide-in drawer panel -->
<div
    id="mobile-drawer"
    class="fixed top-0 right-0 z-[70] h-full w-72 bg-white shadow-2xl translate-x-full transition-transform duration-300 ease-in-out md:hidden"
>
    <!-- Drawer header with close button -->
    <div
        class="flex items-center justify-between px-6 h-16 border-b border-gray-100"
    >
        <span class="font-bold text-lg text-[#151617]">Menu</span>
        <button
            id="drawer-close"
            class="text-[#343a40] hover:text-[#68cb5b] transition-colors duration-200"
            aria-label="Close menu"
        >
            <svg
                xmlns="http://www.w3.org/2000/svg"
                class="w-6 h-6"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M6 18L18 6M6 6l12 12"></path>
            </svg>
        </button>
    </div>

    <!-- Drawer nav links -->
    <div class="flex flex-col py-4">
        <!-- Home -->
        <a
            href="/"
            class:list={[
                "group flex items-center gap-4 px-6 py-3.5 transition-all duration-300 hover:bg-[#68cb5b]/5 hover:pl-8",
                isActive("/")
                    ? "text-[#68cb5b] bg-[#68cb5b]/5 border-r-3 border-[#68cb5b]"
                    : "text-[#343a40] hover:text-[#68cb5b]",
            ]}
        >
            <span class="text-[15px] font-bold">Home</span>
        </a>

        <!-- Games -->
        <a
            href="/category/games"
            class:list={[
                "group flex items-center gap-4 px-6 py-3.5 transition-all duration-300 hover:bg-[#68cb5b]/5 hover:pl-8",
                isActive("/category/games")
                    ? "text-[#68cb5b] bg-[#68cb5b]/5 border-r-3 border-[#68cb5b]"
                    : "text-[#343a40] hover:text-[#68cb5b]",
            ]}
        >
            <span class="text-[15px] font-bold">Games</span>
        </a>

        <!-- Apps -->
        <a
            href="/category/apps"
            class:list={[
                "group flex items-center gap-4 px-6 py-3.5 transition-all duration-300 hover:bg-[#68cb5b]/5 hover:pl-8",
                isActive("/category/apps")
                    ? "text-[#68cb5b] bg-[#68cb5b]/5 border-r-3 border-[#68cb5b]"
                    : "text-[#343a40] hover:text-[#68cb5b]",
            ]}
        >
            <span class="text-[15px] font-bold">Apps</span>
        </a>

        <!-- Tools -->
        <a
            href="/category/tools"
            class:list={[
                "group flex items-center gap-4 px-6 py-3.5 transition-all duration-300 hover:bg-[#68cb5b]/5 hover:pl-8",
                isActive("/category/tools")
                    ? "text-[#68cb5b] bg-[#68cb5b]/5 border-r-3 border-[#68cb5b]"
                    : "text-[#343a40] hover:text-[#68cb5b]",
            ]}
        >
            <span class="text-[15px] font-bold">Tools</span>
        </a>

        <!-- Search -->
        <a
            href="/#search"
            class="group flex items-center gap-4 px-6 py-3.5 text-[#343a40] hover:text-[#68cb5b] transition-all duration-300 hover:bg-[#68cb5b]/5 hover:pl-8"
        >
            <span class="text-[15px] font-bold">Search</span>
        </a>
    </div>
</div>

<script>
    // Mobile drawer toggle
    const menuToggle = document.getElementById("menu-toggle");
    const overlay = document.getElementById("mobile-overlay");
    const drawer = document.getElementById("mobile-drawer");
    const drawerClose = document.getElementById("drawer-close");

    function openDrawer() {
        overlay?.classList.remove("opacity-0", "pointer-events-none");
        overlay?.classList.add("opacity-100", "pointer-events-auto");
        drawer?.classList.remove("translate-x-full");
        drawer?.classList.add("translate-x-0");
        menuToggle?.setAttribute("aria-expanded", "true");
        document.body.style.overflow = "hidden";
    }

    function closeDrawer() {
        overlay?.classList.add("opacity-0", "pointer-events-none");
        overlay?.classList.remove("opacity-100", "pointer-events-auto");
        drawer?.classList.add("translate-x-full");
        drawer?.classList.remove("translate-x-0");
        menuToggle?.setAttribute("aria-expanded", "false");
        document.body.style.overflow = "";
    }

    menuToggle?.addEventListener("click", openDrawer);
    drawerClose?.addEventListener("click", closeDrawer);
    overlay?.addEventListener("click", closeDrawer);

    // Close drawer on link click
    drawer?.querySelectorAll("a").forEach((link) => {
        link.addEventListener("click", closeDrawer);
    });

    // Navbar scroll effect — solid bg + shadow when scrolled
    const nav = document.getElementById("main-nav");

    function handleNavScroll() {
        if (!nav) return;
        if (window.scrollY > 50) {
            nav.classList.remove(
                "bg-white/80",
                "backdrop-blur-md",
                "shadow-[0_1px_0_0_rgba(0,0,0,0.05)]",
            );
            nav.classList.add("bg-white", "shadow-md");
        } else {
            nav.classList.add(
                "bg-white/80",
                "backdrop-blur-md",
                "shadow-[0_1px_0_0_rgba(0,0,0,0.05)]",
            );
            nav.classList.remove("bg-white", "shadow-md");
        }
    }

    window.addEventListener("scroll", handleNavScroll, { passive: true });
    handleNavScroll(); // Run on load
</script>
