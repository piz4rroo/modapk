---
const currentPath = Astro.url.pathname;

function isActive(href: string): boolean {
    if (href === "/") return currentPath === "/";
    return currentPath.startsWith(href);
}
---

<nav
    id="main-nav"
    class="fixed top-0 left-0 right-0 z-50 border-b-[3px] border-[#101010] bg-[#fffbeb] shadow-[0_5px_0_#101010] transition-all duration-300"
>
    <div
        class="max-w-[1200px] mx-auto px-6 md:px-8 h-16 md:h-20 flex items-center justify-between"
    >
        <!-- Logo -->
        <a
            href="/"
            class="flex items-center gap-2.5 text-lg font-black tracking-tight text-[#101010]"
        >
            <img src="/icon.png" alt="Rrmod" class="h-8 w-8 border-2 border-[#101010] object-cover shadow-[3px_3px_0_#101010]" />
            <span class="display-font">Rrmod</span>
        </a>

        <!-- Desktop nav links -->
        <div class="hidden md:flex items-center gap-8">
            <!-- Home -->
            <a
                href="/"
                class:list={[
                    "nav-link relative flex flex-col items-center gap-1 group transition-all duration-200 hover:-translate-y-0.5",
                    isActive("/") ? "text-[#101010]" : "text-[#101010]",
                ]}
            >
                <span
                    class:list={[
                        "text-[13px] font-bold transition-colors duration-300",
                        isActive("/")
                            ? "bg-[#ffee32] px-2 py-1 border-2 border-[#101010] shadow-[3px_3px_0_#101010]"
                            : "group-hover:bg-[#ff4fd8] group-hover:px-2 group-hover:py-1 group-hover:border-2 group-hover:border-[#101010]",
                    ]}>Home</span
                >
                <span class:list={["absolute -bottom-2 h-1 bg-[#101010] transition-all duration-200", isActive("/") ? "w-full" : "w-0 group-hover:w-full"]}></span>
            </a>

            <!-- Games -->
            <a
                href="/category/games"
                class:list={[
                    "nav-link relative flex flex-col items-center gap-1 group transition-all duration-200 hover:-translate-y-0.5",
                    isActive("/category/games")
                        ? "text-[#101010]"
                        : "text-[#101010]",
                ]}
            >
                <span
                    class:list={[
                        "text-[13px] font-bold transition-colors duration-300",
                        isActive("/category/games")
                            ? "bg-[#ffee32] px-2 py-1 border-2 border-[#101010] shadow-[3px_3px_0_#101010]"
                            : "group-hover:bg-[#22c55e] group-hover:px-2 group-hover:py-1 group-hover:border-2 group-hover:border-[#101010]",
                    ]}>Games</span
                >
                <span class:list={["absolute -bottom-2 h-1 bg-[#101010] transition-all duration-200", isActive("/category/games") ? "w-full" : "w-0 group-hover:w-full"]}></span>
            </a>

            <!-- Apps -->
            <a
                href="/category/apps"
                class:list={[
                    "nav-link relative flex flex-col items-center gap-1 group transition-all duration-200 hover:-translate-y-0.5",
                    isActive("/category/apps")
                        ? "text-[#101010]"
                        : "text-[#101010]",
                ]}
            >
                <span
                    class:list={[
                        "text-[13px] font-bold transition-colors duration-300",
                        isActive("/category/apps")
                            ? "bg-[#ffee32] px-2 py-1 border-2 border-[#101010] shadow-[3px_3px_0_#101010]"
                            : "group-hover:bg-[#38bdf8] group-hover:px-2 group-hover:py-1 group-hover:border-2 group-hover:border-[#101010]",
                    ]}>Apps</span
                >
                <span class:list={["absolute -bottom-2 h-1 bg-[#101010] transition-all duration-200", isActive("/category/apps") ? "w-full" : "w-0 group-hover:w-full"]}></span>
            </a>

            <!-- Tools -->
            <a
                href="/category/tools"
                class:list={[
                    "nav-link relative flex flex-col items-center gap-1 group transition-all duration-200 hover:-translate-y-0.5",
                    isActive("/category/tools")
                        ? "text-[#101010]"
                        : "text-[#101010]",
                ]}
            >
                <span
                    class:list={[
                        "text-[13px] font-bold transition-colors duration-300",
                        isActive("/category/tools")
                            ? "bg-[#ffee32] px-2 py-1 border-2 border-[#101010] shadow-[3px_3px_0_#101010]"
                            : "group-hover:bg-[#ff5a1f] group-hover:px-2 group-hover:py-1 group-hover:border-2 group-hover:border-[#101010]",
                    ]}>Tools</span
                >
                <span class:list={["absolute -bottom-2 h-1 bg-[#101010] transition-all duration-200", isActive("/category/tools") ? "w-full" : "w-0 group-hover:w-full"]}></span>
            </a>

        </div>

        <!-- Mobile hamburger -->
        <button
            id="menu-toggle"
            class="border-2 border-[#101010] bg-white p-2 text-[#101010] shadow-[3px_3px_0_#101010] transition-colors duration-200 hover:bg-[#ffee32] md:hidden"
            aria-label="Toggle menu"
            aria-expanded="false"
        >
            <svg
                id="icon-hamburger"
                xmlns="http://www.w3.org/2000/svg"
                class="w-6 h-6"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
        </button>
    </div>
</nav>

<!-- Mobile slide-in drawer overlay -->
<div
    id="mobile-overlay"
    class="fixed inset-0 z-[60] bg-black/60 opacity-0 pointer-events-none transition-opacity duration-200 md:hidden"
>
</div>

<!-- Mobile slide-in drawer panel -->
<div
    id="mobile-drawer"
    class="fixed top-0 right-0 z-[70] h-full w-72 translate-x-full border-l-[4px] border-[#101010] bg-[#fffbeb] shadow-[-8px_0_0_#101010] transition-transform duration-300 ease-in-out md:hidden"
>
    <!-- Drawer header with close button -->
    <div
        class="flex h-16 items-center justify-between border-b-[3px] border-[#101010] px-6"
    >
        <span class="display-font text-lg text-[#101010]">Menu</span>
        <button
            id="drawer-close"
            class="border-2 border-[#101010] bg-white p-1 text-[#101010] shadow-[3px_3px_0_#101010] transition-colors duration-200 hover:bg-[#ff4fd8]"
            aria-label="Close menu"
        >
            <svg
                xmlns="http://www.w3.org/2000/svg"
                class="w-6 h-6"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M6 18L18 6M6 6l12 12"></path>
            </svg>
        </button>
    </div>

    <!-- Drawer nav links -->
    <div class="flex flex-col py-4">
        <!-- Home -->
        <a
            href="/"
            class:list={[
                "group flex items-center gap-4 px-6 py-3.5 transition-all duration-200 hover:bg-[#ffee32] hover:pl-8",
                isActive("/")
                    ? "text-[#101010] bg-[#ffee32] border-r-[6px] border-[#101010]"
                    : "text-[#101010]",
            ]}
        >
            <span class="text-[15px] font-bold">Home</span>
        </a>

        <!-- Games -->
        <a
            href="/category/games"
            class:list={[
                "group flex items-center gap-4 px-6 py-3.5 transition-all duration-200 hover:bg-[#22c55e] hover:pl-8",
                isActive("/category/games")
                    ? "text-[#101010] bg-[#22c55e] border-r-[6px] border-[#101010]"
                    : "text-[#101010]",
            ]}
        >
            <span class="text-[15px] font-bold">Games</span>
        </a>

        <!-- Apps -->
        <a
            href="/category/apps"
            class:list={[
                "group flex items-center gap-4 px-6 py-3.5 transition-all duration-200 hover:bg-[#38bdf8] hover:pl-8",
                isActive("/category/apps")
                    ? "text-[#101010] bg-[#38bdf8] border-r-[6px] border-[#101010]"
                    : "text-[#101010]",
            ]}
        >
            <span class="text-[15px] font-bold">Apps</span>
        </a>

        <!-- Tools -->
        <a
            href="/category/tools"
            class:list={[
                "group flex items-center gap-4 px-6 py-3.5 transition-all duration-200 hover:bg-[#ff5a1f] hover:pl-8",
                isActive("/category/tools")
                    ? "text-[#101010] bg-[#ff5a1f] border-r-[6px] border-[#101010]"
                    : "text-[#101010]",
            ]}
        >
            <span class="text-[15px] font-bold">Tools</span>
        </a>

    </div>
</div>

<script>
    // Mobile drawer toggle
    const menuToggle = document.getElementById("menu-toggle");
    const overlay = document.getElementById("mobile-overlay");
    const drawer = document.getElementById("mobile-drawer");
    const drawerClose = document.getElementById("drawer-close");

    function openDrawer() {
        overlay?.classList.remove("opacity-0", "pointer-events-none");
        overlay?.classList.add("opacity-100", "pointer-events-auto");
        drawer?.classList.remove("translate-x-full");
        drawer?.classList.add("translate-x-0");
        menuToggle?.setAttribute("aria-expanded", "true");
        document.body.style.overflow = "hidden";
    }

    function closeDrawer() {
        overlay?.classList.add("opacity-0", "pointer-events-none");
        overlay?.classList.remove("opacity-100", "pointer-events-auto");
        drawer?.classList.add("translate-x-full");
        drawer?.classList.remove("translate-x-0");
        menuToggle?.setAttribute("aria-expanded", "false");
        document.body.style.overflow = "";
    }

    menuToggle?.addEventListener("click", openDrawer);
    drawerClose?.addEventListener("click", closeDrawer);
    overlay?.addEventListener("click", closeDrawer);

    // Close drawer on link click
    drawer?.querySelectorAll("a").forEach((link) => {
        link.addEventListener("click", closeDrawer);
    });

    // Navbar scroll effect — solid bg + shadow when scrolled
    const nav = document.getElementById("main-nav");

    function handleNavScroll() {
        if (!nav) return;
        if (window.scrollY > 50) {
            nav.classList.add("bg-white");
        } else {
            nav.classList.remove("bg-white");
        }
    }

    window.addEventListener("scroll", handleNavScroll, { passive: true });
    handleNavScroll(); // Run on load
</script>
