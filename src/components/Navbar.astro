---
const currentPath = Astro.url.pathname;

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<nav id="main-nav" class="fixed top-0 left-0 right-0 z-50 bg-white/80 backdrop-blur-md shadow-[0_1px_0_0_rgba(0,0,0,0.05)] transition-all duration-300">
  <div class="max-w-[1200px] mx-auto px-6 md:px-8 h-16 md:h-20 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2.5 font-bold text-lg tracking-tight text-[#151617]">
      <span
        class="inline-block w-7 h-7 rounded-lg"
        style="background: linear-gradient(135deg, #54b247 0%, #68cb5b 100%);"
        aria-hidden="true"
      ></span>
      <span>ModVault</span>
    </a>

    <!-- Desktop nav links -->
    <div class="hidden md:flex items-center gap-8">
      <!-- Home -->
      <a
        href="/"
        class:list={[
          'flex flex-col items-center gap-1 group transition-colors duration-200',
          isActive('/') ? 'text-[#68cb5b]' : 'text-[#343a40]'
        ]}
      >
        <svg xmlns="http://www.w3.org/2000/svg" class:list={['w-5 h-5 transition-colors duration-200', isActive('/') ? 'text-[#68cb5b]' : 'text-[#e2e5e2] group-hover:text-[#68cb5b]']} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0a1 1 0 01-1-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 01-1 1h-2z" />
        </svg>
        <span class:list={['text-[13px] font-bold transition-colors duration-200', isActive('/') ? 'text-[#68cb5b]' : 'group-hover:text-[#68cb5b]']}>Home</span>
      </a>

      <!-- Games -->
      <a
        href="/category/games"
        class:list={[
          'flex flex-col items-center gap-1 group transition-colors duration-200',
          isActive('/category/games') ? 'text-[#68cb5b]' : 'text-[#343a40]'
        ]}
      >
        <svg xmlns="http://www.w3.org/2000/svg" class:list={['w-5 h-5 transition-colors duration-200', isActive('/category/games') ? 'text-[#68cb5b]' : 'text-[#e2e5e2] group-hover:text-[#68cb5b]']} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z" />
        </svg>
        <span class:list={['text-[13px] font-bold transition-colors duration-200', isActive('/category/games') ? 'text-[#68cb5b]' : 'group-hover:text-[#68cb5b]']}>Games</span>
      </a>

      <!-- Apps -->
      <a
        href="/category/apps"
        class:list={[
          'flex flex-col items-center gap-1 group transition-colors duration-200',
          isActive('/category/apps') ? 'text-[#68cb5b]' : 'text-[#343a40]'
        ]}
      >
        <svg xmlns="http://www.w3.org/2000/svg" class:list={['w-5 h-5 transition-colors duration-200', isActive('/category/apps') ? 'text-[#68cb5b]' : 'text-[#e2e5e2] group-hover:text-[#68cb5b]']} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" />
        </svg>
        <span class:list={['text-[13px] font-bold transition-colors duration-200', isActive('/category/apps') ? 'text-[#68cb5b]' : 'group-hover:text-[#68cb5b]']}>Apps</span>
      </a>

      <!-- Tools -->
      <a
        href="/category/tools"
        class:list={[
          'flex flex-col items-center gap-1 group transition-colors duration-200',
          isActive('/category/tools') ? 'text-[#68cb5b]' : 'text-[#343a40]'
        ]}
      >
        <svg xmlns="http://www.w3.org/2000/svg" class:list={['w-5 h-5 transition-colors duration-200', isActive('/category/tools') ? 'text-[#68cb5b]' : 'text-[#e2e5e2] group-hover:text-[#68cb5b]']} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.573-1.066z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
        <span class:list={['text-[13px] font-bold transition-colors duration-200', isActive('/category/tools') ? 'text-[#68cb5b]' : 'group-hover:text-[#68cb5b]']}>Tools</span>
      </a>

      <!-- Search button -->
      <button
        id="search-btn"
        class="ml-2 text-[#343a40] hover:text-[#68cb5b] transition-colors duration-200"
        aria-label="Search"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35" />
        </svg>
      </button>
    </div>

    <!-- Mobile hamburger -->
    <button
      id="menu-toggle"
      class="md:hidden text-[#343a40] hover:text-[#68cb5b] transition-colors duration-200"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <svg id="icon-hamburger" xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>
</nav>

<!-- Mobile slide-in drawer overlay -->
<div id="mobile-overlay" class="fixed inset-0 z-[60] bg-black/50 opacity-0 pointer-events-none transition-opacity duration-200 md:hidden"></div>

<!-- Mobile slide-in drawer panel -->
<div id="mobile-drawer" class="fixed top-0 right-0 z-[70] h-full w-72 bg-white shadow-2xl translate-x-full transition-transform duration-300 ease-in-out md:hidden">
  <!-- Drawer header with close button -->
  <div class="flex items-center justify-between px-6 h-16 border-b border-gray-100">
    <span class="font-bold text-lg text-[#151617]">Menu</span>
    <button id="drawer-close" class="text-[#343a40] hover:text-[#68cb5b] transition-colors duration-200" aria-label="Close menu">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Drawer nav links -->
  <div class="flex flex-col py-4">
    <!-- Home -->
    <a
      href="/"
      class:list={[
        'flex items-center gap-4 px-6 py-3.5 transition-colors duration-200 hover:bg-gray-50',
        isActive('/') ? 'text-[#68cb5b]' : 'text-[#343a40] hover:text-[#68cb5b]'
      ]}
    >
      <svg xmlns="http://www.w3.org/2000/svg" class:list={['w-5 h-5 transition-colors duration-200', isActive('/') ? 'text-[#68cb5b]' : 'text-[#e2e5e2]']} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0a1 1 0 01-1-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 01-1 1h-2z" />
      </svg>
      <span class="text-[15px] font-bold">Home</span>
    </a>

    <!-- Games -->
    <a
      href="/category/games"
      class:list={[
        'flex items-center gap-4 px-6 py-3.5 transition-colors duration-200 hover:bg-gray-50',
        isActive('/category/games') ? 'text-[#68cb5b]' : 'text-[#343a40] hover:text-[#68cb5b]'
      ]}
    >
      <svg xmlns="http://www.w3.org/2000/svg" class:list={['w-5 h-5 transition-colors duration-200', isActive('/category/games') ? 'text-[#68cb5b]' : 'text-[#e2e5e2]']} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z" />
      </svg>
      <span class="text-[15px] font-bold">Games</span>
    </a>

    <!-- Apps -->
    <a
      href="/category/apps"
      class:list={[
        'flex items-center gap-4 px-6 py-3.5 transition-colors duration-200 hover:bg-gray-50',
        isActive('/category/apps') ? 'text-[#68cb5b]' : 'text-[#343a40] hover:text-[#68cb5b]'
      ]}
    >
      <svg xmlns="http://www.w3.org/2000/svg" class:list={['w-5 h-5 transition-colors duration-200', isActive('/category/apps') ? 'text-[#68cb5b]' : 'text-[#e2e5e2]']} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" />
      </svg>
      <span class="text-[15px] font-bold">Apps</span>
    </a>

    <!-- Tools -->
    <a
      href="/category/tools"
      class:list={[
        'flex items-center gap-4 px-6 py-3.5 transition-colors duration-200 hover:bg-gray-50',
        isActive('/category/tools') ? 'text-[#68cb5b]' : 'text-[#343a40] hover:text-[#68cb5b]'
      ]}
    >
      <svg xmlns="http://www.w3.org/2000/svg" class:list={['w-5 h-5 transition-colors duration-200', isActive('/category/tools') ? 'text-[#68cb5b]' : 'text-[#e2e5e2]']} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.573-1.066z" />
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
      </svg>
      <span class="text-[15px] font-bold">Tools</span>
    </a>

    <!-- Search -->
    <a
      href="/#search"
      class="flex items-center gap-4 px-6 py-3.5 text-[#343a40] hover:text-[#68cb5b] transition-colors duration-200 hover:bg-gray-50"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-[#e2e5e2]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <circle cx="11" cy="11" r="8" />
        <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35" />
      </svg>
      <span class="text-[15px] font-bold">Search</span>
    </a>
  </div>
</div>

<script>
  // Mobile drawer toggle
  const menuToggle = document.getElementById('menu-toggle');
  const overlay = document.getElementById('mobile-overlay');
  const drawer = document.getElementById('mobile-drawer');
  const drawerClose = document.getElementById('drawer-close');

  function openDrawer() {
    overlay?.classList.remove('opacity-0', 'pointer-events-none');
    overlay?.classList.add('opacity-100', 'pointer-events-auto');
    drawer?.classList.remove('translate-x-full');
    drawer?.classList.add('translate-x-0');
    menuToggle?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }

  function closeDrawer() {
    overlay?.classList.add('opacity-0', 'pointer-events-none');
    overlay?.classList.remove('opacity-100', 'pointer-events-auto');
    drawer?.classList.add('translate-x-full');
    drawer?.classList.remove('translate-x-0');
    menuToggle?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  menuToggle?.addEventListener('click', openDrawer);
  drawerClose?.addEventListener('click', closeDrawer);
  overlay?.addEventListener('click', closeDrawer);

  // Close drawer on link click
  drawer?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', closeDrawer);
  });

  // Navbar scroll effect — solid bg + shadow when scrolled
  const nav = document.getElementById('main-nav');

  function handleNavScroll() {
    if (!nav) return;
    if (window.scrollY > 50) {
      nav.classList.remove('bg-white/80', 'backdrop-blur-md', 'shadow-[0_1px_0_0_rgba(0,0,0,0.05)]');
      nav.classList.add('bg-white', 'shadow-md');
    } else {
      nav.classList.add('bg-white/80', 'backdrop-blur-md', 'shadow-[0_1px_0_0_rgba(0,0,0,0.05)]');
      nav.classList.remove('bg-white', 'shadow-md');
    }
  }

  window.addEventListener('scroll', handleNavScroll, { passive: true });
  handleNavScroll(); // Run on load
</script>
